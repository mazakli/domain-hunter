<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-10">

  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">🔥 Popüler Kuponlar</h1>
    <p class="text-gray-500">Kullanıcılarımızın en çok tercih ettiği ve en yüksek puanlı kuponlar.</p>
  </div>

  <!-- AdSense Placeholder -->
  <!-- <div class="mb-8">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
  </div> -->

  <% if (coupons && coupons.length > 0) { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
    <% coupons.forEach(function(coupon) { %>
    <%- include('partials/coupon-card', { coupon: coupon }) %>
    <% }); %>
  </div>
  <% } else { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
    <div class="text-6xl mb-4">🔥</div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">Henüz Popüler Kupon Yok</h3>
    <p class="text-gray-500">Yakında en popüler kuponlar burada görüntülenecek.</p>
    <a href="/" class="inline-block mt-4 px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Ana Sayfaya Dön</a>
  </div>
  <% } %>

</div>

<%- include('partials/footer') %>
</body>
</html>
