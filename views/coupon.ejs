<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-8">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6 flex flex-wrap items-center gap-1">
    <a href="/" class="hover:text-orange-600">Ana Sayfa</a>
    <span>/</span>
    <a href="/kategori/<%= coupon.category_slug %>" class="hover:text-orange-600"><%= coupon.category_name %></a>
    <span>/</span>
    <a href="/magaza/<%= coupon.store_slug %>" class="hover:text-orange-600"><%= coupon.store_name %></a>
    <span>/</span>
    <span class="text-gray-800 font-medium truncate max-w-xs"><%= coupon.title %></span>
  </nav>

  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Main Content -->
    <div class="flex-1 min-w-0">
      <!-- Main Coupon Card -->
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mb-8">
        <!-- Store Header -->
        <div class="flex items-center gap-4 px-6 py-5 border-b border-gray-100" style="background: linear-gradient(90deg, #fff7f0, #fff);">
          <% if (coupon.logo_url) { %>
            <img src="<%= coupon.logo_url %>" alt="<%= coupon.store_name %>" class="w-16 h-16 object-contain rounded-xl border border-gray-100 bg-white p-1" />
          <% } else { %>
            <div class="w-16 h-16 rounded-xl flex items-center justify-center text-white text-2xl font-bold flex-shrink-0" style="background:#FF6B00;">
              <%= (coupon.store_name || 'K').charAt(0).toUpperCase() %>
            </div>
          <% } %>
          <div>
            <a href="/magaza/<%= coupon.store_slug %>" class="text-lg font-bold text-gray-800 hover:text-orange-600 transition"><%= coupon.store_name %></a>
            <div class="flex flex-wrap gap-2 mt-1">
              <% if (coupon.is_verified == 1) { %>
              <span class="inline-flex items-center gap-1 text-xs bg-green-100 text-green-700 font-semibold px-2 py-0.5 rounded-full">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Doğrulanmış Kupon
              </span>
              <% } %>
              <% if (coupon.is_exclusive == 1) { %>
              <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full text-white" style="background:#FF6B00;">Özel</span>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Coupon Body -->
        <div class="px-6 py-6">
          <h1 class="text-2xl font-bold text-gray-900 mb-3"><%= coupon.title %></h1>
          <% if (coupon.description) { %>
          <p class="text-gray-600 mb-5"><%= coupon.description %></p>
          <% } %>

          <!-- Discount Badge -->
          <div class="mb-6">
            <% if (coupon.discount_type === 'percent') { %>
              <span class="inline-block bg-green-100 text-green-700 text-2xl font-extrabold px-5 py-2 rounded-xl"><%= coupon.discount_value %>% İndirim</span>
            <% } else if (coupon.discount_type === 'fixed') { %>
              <span class="inline-block bg-blue-100 text-blue-700 text-2xl font-extrabold px-5 py-2 rounded-xl"><%= coupon.discount_value %> TL İndirim</span>
            <% } else if (coupon.discount_type === 'free_shipping') { %>
              <span class="inline-block bg-purple-100 text-purple-700 text-2xl font-extrabold px-5 py-2 rounded-xl">Ücretsiz Kargo</span>
            <% } else { %>
              <span class="inline-block text-white text-2xl font-extrabold px-5 py-2 rounded-xl" style="background:#FF6B00;"><%= coupon.discount_value || 'Özel Fırsat' %></span>
            <% } %>
          </div>

          <!-- Coupon Code + Copy Button -->
          <% if (coupon.code) { %>
          <div class="mb-6">
            <p class="text-sm text-gray-500 font-medium mb-2">Kupon Kodu</p>
            <div class="flex items-center gap-3">
              <div class="flex-1 bg-orange-50 border-2 border-dashed rounded-xl px-5 py-3 font-mono text-xl font-bold tracking-widest text-gray-800" style="border-color:#FF6B00;" id="coupon-code-box">
                <span id="main-code-display"><%= coupon.code.substring(0, 4) %><span class="blur-sm select-none text-gray-400">••••••</span></span>
              </div>
              <button id="copy-btn" onclick="revealAndCopy('<%= coupon.code %>')" class="text-white text-base font-bold px-6 py-3 rounded-xl transition hover:opacity-90 whitespace-nowrap" style="background:#FF6B00;">
                Kodu Kopyala
              </button>
            </div>
          </div>
          <% } else { %>
          <a href="<%= coupon.affiliate_url || '#' %>" target="_blank" rel="nofollow noopener" class="inline-block text-white text-lg font-bold px-8 py-3 rounded-xl mb-6 transition hover:opacity-90" style="background:#FF6B00;">
            Fırsatı Kullan →
          </a>
          <% } %>

          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-3 mb-6">
            <% if (currentUser) { %>
            <form action="/kupon/<%= coupon.id %>/kaydet" method="POST">
              <button type="submit" class="flex items-center gap-2 px-5 py-2 rounded-lg border-2 font-semibold transition <%= isSaved ? 'text-white' : 'text-gray-700 hover:border-orange-500 hover:text-orange-600' %>" style="<%= isSaved ? 'background:#FF6B00; border-color:#FF6B00;' : 'border-color:#d1d5db;' %>">
                <svg class="w-4 h-4" fill="<%= isSaved ? 'white' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                <%= isSaved ? 'Kaydedildi' : 'Kaydet' %>
              </button>
            </form>
            <% } %>
            <a href="<%= coupon.affiliate_url || '#' %>" target="_blank" rel="nofollow noopener" class="flex items-center gap-2 px-5 py-2 rounded-lg border-2 border-gray-200 text-gray-700 font-semibold hover:border-orange-400 hover:text-orange-600 transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Mağazaya Git
            </a>
          </div>

          <!-- Meta Info -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center border-t border-gray-100 pt-5">
            <div>
              <div class="text-xs text-gray-400 mb-1">Son Kullanma</div>
              <div class="text-sm font-semibold text-gray-700">
                <% if (coupon.expiry_date) { %>
                  <%= new Date(coupon.expiry_date).toLocaleDateString('tr-TR') %>
                <% } else { %>
                  Süresiz
                <% } %>
              </div>
            </div>
            <div>
              <div class="text-xs text-gray-400 mb-1">Kullanım</div>
              <div class="text-sm font-semibold text-gray-700"><%= coupon.use_count || 0 %> kez</div>
            </div>
            <div>
              <div class="text-xs text-gray-400 mb-1">Görüntüleme</div>
              <div class="text-sm font-semibold text-gray-700"><%= coupon.view_count || 0 %></div>
            </div>
            <div>
              <div class="text-xs text-gray-400 mb-1">Puan</div>
              <div class="text-sm font-semibold text-gray-700">
                <% var avg = coupon.rating_count > 0 ? Math.round(coupon.rating_sum / coupon.rating_count) : 0; %>
                <% for (var i = 1; i <= 5; i++) { %>
                  <span class="<%= i <= avg ? 'text-yellow-400' : 'text-gray-300' %>">★</span>
                <% } %>
                <span class="text-xs text-gray-400">(<%= coupon.rating_count || 0 %>)</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Rating Section -->
      <div class="bg-white rounded-2xl shadow border border-gray-100 px-6 py-5 mb-8">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Bu kuponu değerlendirin</h3>
        <% if (currentUser) { %>
        <form action="/kupon/<%= coupon.id %>/puan" method="POST" class="flex items-center gap-3">
          <div class="flex gap-1" id="star-rating">
            <% for (var s = 1; s <= 5; s++) { %>
            <label class="cursor-pointer">
              <input type="radio" name="rating" value="<%= s %>" class="sr-only" <%= userRating === s ? 'checked' : '' %> />
              <span class="text-3xl <%= (userRating && s <= userRating) ? 'text-yellow-400' : 'text-gray-300' %> hover:text-yellow-400 transition star-btn" data-val="<%= s %>">★</span>
            </label>
            <% } %>
          </div>
          <button type="submit" class="px-5 py-2 rounded-lg text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Gönder</button>
        </form>
        <% } else { %>
        <p class="text-gray-500">Puanlama yapabilmek için <a href="/giris" class="font-semibold hover:underline" style="color:#FF6B00;">giriş yapın</a>.</p>
        <% } %>
      </div>

      <!-- How to Use -->
      <div class="bg-white rounded-2xl shadow border border-gray-100 px-6 py-5 mb-8">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Nasıl Kullanılır?</h3>
        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background:#FF6B00;">1</span>
            <span class="text-gray-600">Yukarıdaki "Kodu Kopyala" butonuna tıklayarak kupon kodunu panoya kopyalayın.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background:#FF6B00;">2</span>
            <span class="text-gray-600"><a href="/magaza/<%= coupon.store_slug %>" class="font-semibold hover:underline" style="color:#FF6B00;"><%= coupon.store_name %></a> web sitesine gidin ve ürünlerinizi sepetinize ekleyin.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background:#FF6B00;">3</span>
            <span class="text-gray-600">Ödeme sayfasında "İndirim Kodu" veya "Kupon Kodu" alanına kopyaladığınız kodu yapıştırın.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background:#FF6B00;">4</span>
            <span class="text-gray-600">İndirim tutarı sepetinize yansıyacak, siparişinizi tamamlayın ve tasarruf edin!</span>
          </li>
        </ol>
      </div>

      <!-- AdSense Placeholder -->
      <!-- <div class="my-4">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
      </div> -->

      <!-- Same Store Coupons -->
      <% if (storeCoupons && storeCoupons.length > 0) { %>
      <div>
        <h3 class="text-xl font-bold text-gray-800 mb-5"><%= coupon.store_name %> Diğer Kuponları</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% storeCoupons.forEach(function(c) { %>
          <%- include('partials/coupon-card', { coupon: c }) %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Reviews Section -->
      <section id="reviews" class="mt-8">
        <h2 class="text-xl font-bold text-gray-800 mb-6">Kullanıcı Yorumları</h2>
        <% if (reviews && reviews.length > 0) { %>
        <div class="space-y-4 mb-8">
          <% reviews.forEach(function(r) { %>
          <div class="bg-white rounded-xl border border-gray-100 p-4">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background:#FF6B00"><%= r.username.charAt(0).toUpperCase() %></div>
              <span class="font-semibold text-sm text-gray-800"><%= r.username %></span>
              <div class="flex gap-0.5">
                <% for(var ri=1;ri<=5;ri++) { %>
                <svg class="w-4 h-4 <%= ri <= r.rating ? 'text-yellow-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <% } %>
              </div>
              <span class="text-xs text-gray-400 ml-auto"><%= new Date(r.created_at).toLocaleDateString('tr-TR') %></span>
            </div>
            <% if (r.comment) { %><p class="text-sm text-gray-600"><%= r.comment %></p><% } %>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p class="text-gray-400 text-sm mb-8">Henüz yorum yok. İlk yorumu sen yap!</p>
        <% } %>

        <% if (currentUser) { %>
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-6">
          <h3 class="font-bold text-gray-800 mb-4">Yorum Yap</h3>
          <form action="/kupon/<%= coupon.id %>/review" method="POST">
            <div class="mb-4">
              <label class="block text-sm font-semibold text-gray-700 mb-2">Puan</label>
              <div class="flex gap-2" id="starRating">
                <% for(var si=1;si<=5;si++) { %>
                <label class="cursor-pointer">
                  <input type="radio" name="rating" value="<%= si %>" class="sr-only" required>
                  <svg class="w-8 h-8 text-gray-300 hover:text-yellow-400 transition star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                </label>
                <% } %>
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-semibold text-gray-700 mb-2">Yorum (isteğe bagli)</label>
              <textarea name="comment" rows="3" placeholder="Kupon hakkinda deneyiminizi paylasin..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 resize-none"></textarea>
            </div>
            <button type="submit" class="text-white px-6 py-2.5 rounded-xl font-semibold text-sm hover:opacity-90 transition" style="background:#FF6B00">Yorum Gönder</button>
          </form>
        </div>
        <% } else { %>
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-6 text-center">
          <p class="text-gray-600 mb-3">Yorum yapmak için giriş yapmanız gerekiyor.</p>
          <a href="/giris?redirect=/kupon/<%= coupon.id %>#reviews" class="text-white px-6 py-2.5 rounded-xl font-semibold text-sm hover:opacity-90 transition inline-block" style="background:#FF6B00">Giriş Yap</a>
        </div>
        <% } %>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="lg:w-72 flex-shrink-0">
      <!-- Popular Coupons -->
      <div class="bg-white rounded-2xl shadow border border-gray-100 overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100" style="background:#FF6B00;">
          <h3 class="text-white font-bold text-lg">Popüler Kuponlar</h3>
        </div>
        <div class="divide-y divide-gray-50">
          <% popularCoupons.forEach(function(c) { %>
          <div class="px-5 py-3 hover:bg-orange-50 transition">
            <a href="/kupon/<%= c.id %>-<%= (c.slug || '') %>" class="text-sm font-semibold text-gray-700 hover:text-orange-600 transition block mb-1 line-clamp-2"><%= c.title %></a>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400"><%= c.store_name %></span>
              <% if (c.discount_type === 'percent') { %>
                <span class="text-xs bg-green-100 text-green-700 font-bold px-2 py-0.5 rounded-full"><%= c.discount_value %>%</span>
              <% } else if (c.discount_type === 'fixed') { %>
                <span class="text-xs bg-blue-100 text-blue-700 font-bold px-2 py-0.5 rounded-full"><%= c.discount_value %> TL</span>
              <% } else if (c.discount_type === 'free_shipping') { %>
                <span class="text-xs bg-purple-100 text-purple-700 font-bold px-2 py-0.5 rounded-full">Kargo</span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </aside>
  </div>
</div>

<script>
function revealAndCopy(code) {
  var display = document.getElementById('main-code-display');
  if (display) display.innerHTML = '<span class="tracking-widest">' + code + '</span>';
  var btn = document.getElementById('copy-btn');
  navigator.clipboard.writeText(code).then(function() {
    btn.textContent = '✓ Kopyalandı!';
    btn.style.background = '#16a34a';
    setTimeout(function() { btn.textContent = 'Kodu Kopyala'; btn.style.background = '#FF6B00'; }, 3000);
  }).catch(function() {
    btn.textContent = 'Kodu Kopyala';
  });
}
// Star rating hover effect
document.querySelectorAll('.star-btn').forEach(function(star) {
  star.addEventListener('mouseenter', function() {
    var val = parseInt(this.dataset.val);
    document.querySelectorAll('.star-btn').forEach(function(s) {
      s.classList.toggle('text-yellow-400', parseInt(s.dataset.val) <= val);
      s.classList.toggle('text-gray-300', parseInt(s.dataset.val) > val);
    });
  });
});
</script>

<%- include('partials/footer') %>
</body>
</html>
