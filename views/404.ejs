<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center py-16 px-4">
  <div class="max-w-lg w-full text-center">

    <!-- Illustration -->
    <div class="relative mb-8">
      <div class="text-8xl font-extrabold" style="color:#FF6B00; opacity:0.15; font-size:12rem; line-height:1; user-select:none;">404</div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-6xl">🔍</div>
      </div>
    </div>

    <h1 class="text-3xl font-extrabold text-gray-900 mb-3">Sayfa Bulunamadı</h1>
    <p class="text-gray-500 text-lg mb-2">Aradığınız sayfa mevcut değil veya taşınmış olabilir.</p>
    <p class="text-gray-400 mb-8">Belki silinmiş bir kupon ya da mağaza aradınız. Endişelenmeyin, ana sayfamızda binlerce güncel kupon sizi bekliyor!</p>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-10">
      <a href="/" class="inline-block text-white font-bold px-8 py-3 rounded-xl transition hover:opacity-90 text-base" style="background:#FF6B00;">
        🏠 Ana Sayfaya Dön
      </a>
      <a href="/ara" class="inline-block border-2 font-bold px-8 py-3 rounded-xl transition hover:bg-orange-50 text-base" style="color:#FF6B00; border-color:#FF6B00;">
        🔍 Kupon Ara
      </a>
    </div>

    <!-- Quick Links -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow p-6">
      <h3 class="font-bold text-gray-700 mb-4">Faydalı Bağlantılar</h3>
      <div class="grid grid-cols-2 gap-3">
        <a href="/yeni-kuponlar" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          🆕 Yeni Kuponlar
        </a>
        <a href="/populer-kuponlar" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          🔥 Popüler Kuponlar
        </a>
        <a href="/magazalar" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          🏬 Tüm Mağazalar
        </a>
        <a href="/kategoriler" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          📂 Kategoriler
        </a>
        <a href="/kupon-ekle" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          ➕ Kupon Ekle
        </a>
        <a href="/iletisim" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-orange-50 hover:bg-orange-100 transition text-sm font-semibold text-gray-700">
          📩 İletişim
        </a>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
