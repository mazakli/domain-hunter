<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-10">

  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6 flex items-center gap-1">
    <a href="/" class="hover:text-orange-600">Ana Sayfa</a>
    <span>/</span>
    <a href="/kategoriler" class="hover:text-orange-600">Kategoriler</a>
    <span>/</span>
    <span class="text-gray-800 font-medium"><%= category.name %></span>
  </nav>

  <!-- Category Header -->
  <div class="rounded-2xl overflow-hidden shadow-lg mb-10">
    <div class="h-3" style="background: <%= category.color || '#FF6B00' %>;"></div>
    <div class="bg-white px-8 py-8 flex flex-col sm:flex-row items-center sm:items-start gap-5">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl font-bold flex-shrink-0" style="background:<%= category.color || '#FF6B00' %>"><%= category.name ? category.name.charAt(0).toUpperCase() : 'K' %></div>
      <div>
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2"><%= category.name %></h1>
        <% if (category.description) { %>
        <p class="text-gray-500 mb-3"><%= category.description %></p>
        <% } %>
        <div class="flex flex-wrap gap-4">
          <span class="text-sm font-semibold text-gray-600">
            <strong><%= (stores && stores.length) || 0 %></strong> Mağaza
          </span>
          <span class="text-sm font-semibold text-gray-600">
            <strong><%= (coupons && coupons.length) || 0 %></strong> Kupon
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Stores in Category -->
  <% if (stores && stores.length > 0) { %>
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-800 mb-5"><%= category.name %> Mağazaları</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% stores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="bg-white rounded-2xl shadow hover:shadow-lg transition border border-gray-100 hover:border-orange-200 p-4 flex flex-col items-center text-center group">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-12 h-12 object-contain rounded-lg mb-2 border border-gray-100" />
        <% } else { %>
        <div class="w-12 h-12 rounded-lg flex items-center justify-center text-white text-xl font-bold mb-2" style="background: <%= category.color || '#FF6B00' %>;">
          <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
        </div>
        <% } %>
        <span class="text-xs font-semibold text-gray-700 group-hover:text-orange-600 transition truncate w-full text-center"><%= store.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= store.active_coupons || store.coupon_count || 0 %> kupon</span>
      </a>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- Coupons in Category -->
  <% if (coupons && coupons.length > 0) { %>
  <section>
    <h2 class="text-2xl font-bold text-gray-800 mb-5"><%= category.name %> Kuponları</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <% coupons.forEach(function(coupon) { %>
      <%- include('partials/coupon-card', { coupon: coupon }) %>
      <% }); %>
    </div>
  </section>
  <% } %>

  <% if ((!coupons || coupons.length === 0) && (!stores || stores.length === 0)) { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#fff3e0;">
      <svg class="w-8 h-8" fill="none" stroke="#FF6B00" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
    </div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">Bu Kategoride Henüz İçerik Yok</h3>
    <p class="text-gray-500 mb-4">Yakında bu kategoride kuponlar eklenecek.</p>
    <a href="/kategoriler" class="inline-block px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Diğer Kategoriler</a>
  </div>
  <% } %>

</div>

<%- include('partials/footer') %>
</body>
</html>
