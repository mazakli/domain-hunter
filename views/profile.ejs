<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-5xl mx-auto px-4 py-10">

  <!-- Profile Header -->
  <div class="bg-white rounded-2xl shadow border border-gray-100 p-6 mb-8 flex items-center gap-5">
    <div class="w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-extrabold flex-shrink-0" style="background:#FF6B00;">
      <%= currentUser && currentUser.username ? currentUser.username.charAt(0).toUpperCase() : 'U' %>
    </div>
    <div>
      <h1 class="text-xl font-extrabold text-gray-900"><%= currentUser && currentUser.username ? currentUser.username : 'Kullanıcı' %></h1>
      <p class="text-gray-500 text-sm"><%= currentUser && currentUser.email ? currentUser.email : '' %></p>
    </div>
    <div class="ml-auto">
      <a href="/cikis" class="px-4 py-2 rounded-lg border-2 border-gray-200 text-gray-600 font-semibold hover:border-red-300 hover:text-red-600 transition text-sm">Çıkış Yap</a>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex gap-1 mb-6 bg-gray-100 p-1 rounded-xl w-fit">
    <button id="tab-saved" onclick="showTab('saved')" class="tab-btn px-6 py-2.5 rounded-lg font-semibold text-sm transition text-white" style="background:#FF6B00;">
      🏷️ Kaydedilen Kuponlar
      <% if (savedCoupons && savedCoupons.length > 0) { %>
      <span class="ml-1 bg-white text-orange-600 text-xs px-1.5 py-0.5 rounded-full"><%= savedCoupons.length %></span>
      <% } %>
    </button>
    <button id="tab-stores" onclick="showTab('stores')" class="tab-btn px-6 py-2.5 rounded-lg font-semibold text-sm transition text-gray-600 hover:text-gray-800">
      🏬 Favori Mağazalar
      <% if (favoriteStores && favoriteStores.length > 0) { %>
      <span class="ml-1 bg-orange-100 text-orange-600 text-xs px-1.5 py-0.5 rounded-full"><%= favoriteStores.length %></span>
      <% } %>
    </button>
  </div>

  <!-- Saved Coupons Tab -->
  <div id="panel-saved">
    <% if (savedCoupons && savedCoupons.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      <% savedCoupons.forEach(function(coupon) { %>
      <%- include('partials/coupon-card', { coupon: coupon }) %>
      <% }); %>
    </div>
    <% } else { %>
    <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
      <div class="text-6xl mb-4">🏷️</div>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">Kaydedilen Kupon Yok</h3>
      <p class="text-gray-500 mb-4">Beğendiğiniz kuponları "Kaydet" butonuna tıklayarak buraya ekleyin.</p>
      <a href="/" class="inline-block px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Kupona Göz At</a>
    </div>
    <% } %>
  </div>

  <!-- Favorite Stores Tab -->
  <div id="panel-stores" class="hidden">
    <% if (favoriteStores && favoriteStores.length > 0) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      <% favoriteStores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="bg-white rounded-2xl shadow hover:shadow-lg transition border border-gray-100 hover:border-orange-200 p-4 flex flex-col items-center text-center group">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-12 h-12 object-contain rounded-xl mb-2 border border-gray-100" />
        <% } else { %>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-xl font-bold mb-2" style="background:#FF6B00;">
          <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
        </div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 transition truncate w-full text-center"><%= store.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= store.active_coupons || store.coupon_count || 0 %> kupon</span>
        <!-- Remove Favorite -->
        <form action="/magaza/<%= store.slug %>/favori" method="POST" class="mt-2" onclick="event.stopPropagation()">
          <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition">❤️ Kaldır</button>
        </form>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
      <div class="text-6xl mb-4">🏬</div>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">Favori Mağaza Yok</h3>
      <p class="text-gray-500 mb-4">Mağaza sayfalarından "Favoriye Ekle" butonuna tıklayarak takip etmeye başlayın.</p>
      <a href="/magazalar" class="inline-block px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Mağazalara Göz At</a>
    </div>
    <% } %>
  </div>

</div>

<script>
function showTab(tab) {
  var tabs = ['saved', 'stores'];
  tabs.forEach(function(t) {
    var btn = document.getElementById('tab-' + t);
    var panel = document.getElementById('panel-' + t);
    if (t === tab) {
      btn.style.background = '#FF6B00';
      btn.style.color = 'white';
      panel.classList.remove('hidden');
    } else {
      btn.style.background = '';
      btn.style.color = '';
      btn.classList.add('text-gray-600');
      panel.classList.add('hidden');
    }
  });
}
</script>

<%- include('partials/footer') %>
</body>
</html>
