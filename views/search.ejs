<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-10">

  <!-- Search Form -->
  <div class="mb-8">
    <h1 class="text-2xl font-extrabold text-gray-900 mb-4">Arama Sonuçları</h1>
    <form action="/ara" method="GET" class="flex gap-3">
      <input type="text" name="q" value="<%= q || '' %>" placeholder="Kupon veya mağaza ara..." class="flex-1 px-5 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 text-base" />
      <button type="submit" class="text-white font-bold px-7 py-3 rounded-xl transition hover:opacity-90 text-base" style="background:#FF6B00;">Ara</button>
    </form>
  </div>

  <!-- Type Filter Tabs -->
  <div class="flex gap-2 mb-8 border-b border-gray-200 pb-0">
    <a href="/ara?q=<%= encodeURIComponent(q || '') %>&tip=tumu" class="px-5 py-2.5 -mb-px font-semibold text-sm rounded-t-lg transition border-b-2 <%= (!type || type === 'tumu') ? 'border-orange-500 text-orange-600 bg-orange-50' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Tümü
    </a>
    <a href="/ara?q=<%= encodeURIComponent(q || '') %>&tip=kuponlar" class="px-5 py-2.5 -mb-px font-semibold text-sm rounded-t-lg transition border-b-2 <%= type === 'kuponlar' ? 'border-orange-500 text-orange-600 bg-orange-50' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Kuponlar
      <% if (coupons && coupons.length > 0) { %>
      <span class="ml-1 text-xs bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded-full"><%= coupons.length %></span>
      <% } %>
    </a>
    <a href="/ara?q=<%= encodeURIComponent(q || '') %>&tip=magazalar" class="px-5 py-2.5 -mb-px font-semibold text-sm rounded-t-lg transition border-b-2 <%= type === 'magazalar' ? 'border-orange-500 text-orange-600 bg-orange-50' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Mağazalar
      <% if (stores && stores.length > 0) { %>
      <span class="ml-1 text-xs bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded-full"><%= stores.length %></span>
      <% } %>
    </a>
  </div>

  <!-- No Results -->
  <% if ((!coupons || coupons.length === 0) && (!stores || stores.length === 0)) { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">Sonuç Bulunamadı</h3>
    <p class="text-gray-500 mb-2">
      <% if (q) { %>"<strong><%= q %></strong>" için sonuç bulunamadı.<% } else { %>Arama yapmak için bir kelime girin.<% } %>
    </p>
    <p class="text-gray-400 text-sm mb-6">Farklı anahtar kelimeler deneyin veya mağazalara göz atın.</p>
    <div class="flex gap-3 justify-center flex-wrap">
      <a href="/magazalar" class="px-6 py-2 rounded-xl border-2 font-semibold transition hover:bg-orange-50" style="color:#FF6B00; border-color:#FF6B00;">Tüm Mağazalar</a>
      <a href="/kategoriler" class="px-6 py-2 rounded-xl border-2 border-gray-200 text-gray-600 font-semibold hover:border-gray-300 transition">Kategoriler</a>
    </div>
  </div>
  <% } %>

  <!-- Coupon Results -->
  <% if ((!type || type === 'tumu' || type === 'kuponlar') && coupons && coupons.length > 0) { %>
  <section class="mb-12">
    <h2 class="text-xl font-bold text-gray-800 mb-5">
      Kuponlar
      <span class="text-base font-normal text-gray-400">(<%= coupons.length %> sonuç)</span>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <% coupons.forEach(function(coupon) { %>
      <%- include('partials/coupon-card', { coupon: coupon }) %>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- Store Results -->
  <% if ((!type || type === 'tumu' || type === 'magazalar') && stores && stores.length > 0) { %>
  <section>
    <h2 class="text-xl font-bold text-gray-800 mb-5">
      Mağazalar
      <span class="text-base font-normal text-gray-400">(<%= stores.length %> sonuç)</span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% stores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="bg-white rounded-2xl shadow hover:shadow-lg transition border border-gray-100 hover:border-orange-200 p-4 flex flex-col items-center text-center group">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-12 h-12 object-contain rounded-lg mb-2 border border-gray-100" />
        <% } else { %>
        <div class="w-12 h-12 rounded-lg flex items-center justify-center text-white text-xl font-bold mb-2" style="background:#FF6B00;">
          <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
        </div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 transition truncate w-full text-center"><%= store.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= store.active_coupons || store.coupon_count || 0 %> kupon</span>
      </a>
      <% }); %>
    </div>
  </section>
  <% } %>

</div>

<%- include('partials/footer') %>
</body>
</html>
