<!-- Top Bar -->
<div class="bg-dark text-white text-xs py-1.5 px-4" style="background:#1a1a2e">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex items-center gap-4">
      <a href="/telegram" class="hover:text-orange-400 transition flex items-center gap-1">
        <svg class="w-3.5 h-3.5 inline" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.96 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Telegram Kanalımız
      </a>
      <span class="text-gray-500">|</span>
      <a href="/kupon/son-eklenenler" class="hover:text-orange-400 transition">🔥 Son Kuponlar</a>
    </div>
    <div class="flex items-center gap-3">
      <% if (currentUser) { %>
        <a href="/profil" class="hover:text-orange-400 transition">👤 <strong class="text-orange-400"><%= currentUser.username %></strong></a>
        <a href="/cikis" class="hover:text-orange-400 transition">Çıkış</a>
      <% } else { %>
        <a href="/giris" class="hover:text-orange-400 transition">Giriş Yap</a>
        <span class="text-gray-500">|</span>
        <a href="/kayit" class="hover:text-orange-400 transition font-semibold">Üye Ol</a>
      <% } %>
    </div>
  </div>
</div>

<!-- Main Navbar -->
<nav class="bg-white shadow-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:#FF6B00">
          <span class="text-white font-bold text-lg">K</span>
        </div>
        <span class="font-bold text-xl" style="color:#1a1a2e">Kuponluk<span style="color:#FF6B00">.com</span></span>
      </a>

      <!-- Search Bar -->
      <form action="/arama" method="GET" class="hidden md:flex flex-1 max-w-xl mx-6">
        <div class="relative w-full">
          <input type="text" name="q" placeholder="Kupon kodu, mağaza veya indirim ara..."
            value="<%= typeof q !== 'undefined' ? q : '' %>"
            class="w-full border border-gray-200 rounded-xl pl-4 pr-12 py-2.5 text-sm focus:outline-none focus:ring-2 transition"
            style="focus:border-color:#FF6B00"
          >
          <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-orange-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
        </div>
      </form>

      <!-- Right -->
      <div class="flex items-center gap-3">
        <a href="/kupon-gonder" class="hidden sm:flex items-center gap-1.5 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:opacity-90 transition" style="background:#FF6B00">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Kupon Gönder
        </a>
        <button id="mobileMenuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <!-- Secondary Nav -->
    <div class="hidden md:flex items-center gap-1 pb-2 border-t border-gray-100 pt-2 text-sm overflow-x-auto scrollbar-hide">
      <a href="/kategoriler" class="whitespace-nowrap px-3 py-1.5 rounded-lg hover:bg-orange-50 font-medium transition text-gray-700 hover:text-orange-600">📂 Kategoriler</a>
      <a href="/magazalar" class="whitespace-nowrap px-3 py-1.5 rounded-lg hover:bg-orange-50 font-medium transition text-gray-700 hover:text-orange-600">🏪 Mağazalar</a>
      <a href="/kupon/son-eklenenler" class="whitespace-nowrap px-3 py-1.5 rounded-lg hover:bg-orange-50 font-medium transition text-gray-700 hover:text-orange-600">🕐 Son Eklenenler</a>
      <a href="/kupon/populer" class="whitespace-nowrap px-3 py-1.5 rounded-lg hover:bg-orange-50 font-medium transition text-gray-700 hover:text-orange-600">🔥 Popüler</a>
      <a href="/telegram" class="whitespace-nowrap px-3 py-1.5 rounded-lg hover:bg-orange-50 font-medium transition text-gray-700 hover:text-orange-600">📱 Telegram</a>
      <span class="text-gray-200 mx-1">|</span>
      <a href="/kategori/moda-giyim" class="whitespace-nowrap px-2 py-1 rounded-lg hover:bg-orange-50 transition text-gray-500 text-xs hover:text-orange-600">👗 Moda</a>
      <a href="/kategori/elektronik" class="whitespace-nowrap px-2 py-1 rounded-lg hover:bg-orange-50 transition text-gray-500 text-xs hover:text-orange-600">📱 Elektronik</a>
      <a href="/kategori/yemek-restoran" class="whitespace-nowrap px-2 py-1 rounded-lg hover:bg-orange-50 transition text-gray-500 text-xs hover:text-orange-600">🍔 Yemek</a>
      <a href="/kategori/seyahat" class="whitespace-nowrap px-2 py-1 rounded-lg hover:bg-orange-50 transition text-gray-500 text-xs hover:text-orange-600">✈️ Seyahat</a>
      <a href="/kategori/spor-outdoor" class="whitespace-nowrap px-2 py-1 rounded-lg hover:bg-orange-50 transition text-gray-500 text-xs hover:text-orange-600">⚽ Spor</a>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-3">
    <form action="/arama" method="GET" class="mb-3">
      <input type="text" name="q" placeholder="Kupon veya mağaza ara..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none">
    </form>
    <div class="grid grid-cols-2 gap-2 text-sm">
      <a href="/kategoriler" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-orange-50 font-medium">📂 Kategoriler</a>
      <a href="/magazalar" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-orange-50 font-medium">🏪 Mağazalar</a>
      <a href="/kupon/son-eklenenler" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-orange-50 font-medium">🕐 Son Eklenenler</a>
      <a href="/kupon/populer" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-orange-50 font-medium">🔥 Popüler</a>
      <a href="/telegram" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-orange-50 font-medium">📱 Telegram</a>
      <a href="/kupon-gonder" class="flex items-center gap-2 px-3 py-2 rounded-lg text-white font-semibold" style="background:#FF6B00">➕ Kupon Gönder</a>
    </div>
  </div>
</nav>
