<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-red sticky-top shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/"><i class="fa-solid fa-pills me-2"></i>Nöbetçi Eczane</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="fa-solid fa-map-location-dot me-1"></i>İller
          </a>
          <div class="dropdown-menu dropdown-menu-end province-dropdown">
            <div class="row g-0 p-2">
              <%
                var alpha = {};
                iller.forEach(function(i){
                  var letter = i.name[0].toUpperCase();
                  if(!alpha[letter]) alpha[letter]=[];
                  alpha[letter].push(i);
                });
              %>
              <% Object.keys(alpha).sort().forEach(function(letter){ %>
              <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="dropdown-header fw-bold text-danger small"><%= letter %></div>
                <% alpha[letter].forEach(function(prov){ %>
                <a class="dropdown-item py-0 small" href="/nobetci-<%= prov.slug %>"><%= prov.name %></a>
                <% }); %>
              </div>
              <% }); %>
            </div>
          </div>
        </li>
      </ul>
    </div>
  </div>
</nav>

<main>
<div class="container py-4">

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-danger text-decoration-none"><i class="fa-solid fa-house me-1"></i>Ana Sayfa</a></li>
      <li class="breadcrumb-item active"><%= il.name %></li>
    </ol>
  </nav>

  <h1 class="h2 fw-bold text-danger mb-1">
    <i class="fa-solid fa-pills me-2"></i><%= il.name %> Nöbetçi Eczaneleri
  </h1>
  <p class="text-muted mb-4">Aşağıdan tarih seçerek nöbetçi eczane listesini görüntüleyin.</p>

  <ul class="nav nav-tabs day-tabs mb-4" id="dayTabs">
    <li class="nav-item">
      <button class="nav-link day-tab" data-date="<%= today.dun.iso %>">
        <span class="d-none d-sm-inline">Dün &mdash; </span><%= today.dun.label %>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link day-tab active" data-date="<%= today.bugun.iso %>">
        <i class="fa-solid fa-circle-dot me-1"></i><strong>Bugün</strong>
        <span class="d-none d-sm-inline"> &mdash; <%= today.bugun.label %></span>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link day-tab" data-date="<%= today.yarin.iso %>">
        <span class="d-none d-sm-inline">Yarın &mdash; </span><%= today.yarin.label %>
      </button>
    </li>
  </ul>

  <div class="row g-4">

    <div class="col-md-3 order-md-last">
      <div class="sidebar-card">
        <div class="sidebar-header">
          <i class="fa-solid fa-map-pin me-2"></i><%= il.name %> İlçeleri
        </div>
        <div class="sidebar-body">
          <a href="/nobetci-<%= il.slug %>" class="sidebar-link active">
            <i class="fa-solid fa-city me-1"></i>Tüm İlçeler
          </a>
          <% il.districts.forEach(function(d){ %>
          <a href="/nobetci-<%= il.slug %>-<%= d.slug %>" class="sidebar-link"><%= d.name %></a>
          <% }); %>
        </div>
      </div>
    </div>

    <div class="col-md-9">
      <div id="loadingSpinner" class="text-center py-5">
        <div class="spinner-border text-danger" style="width:3rem;height:3rem" role="status"></div>
        <p class="mt-3 text-muted">Nöbetçi eczaneler yükleniyor...</p>
      </div>
      <div id="pharmacyTableWrap" style="display:none">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span id="pharmacyCount" class="badge bg-danger fs-6"></span>
          <input type="text" id="tableSearch" class="form-control form-control-sm w-auto" placeholder="Tabloda ara...">
        </div>
        <div class="table-responsive">
          <table class="table table-hover pharmacy-table">
            <thead>
              <tr>
                <th>#</th>
                <th><i class="fa-solid fa-prescription-bottle me-1"></i>Eczane Adı</th>
                <th><i class="fa-solid fa-location-dot me-1"></i>Adres</th>
                <th><i class="fa-solid fa-phone me-1"></i>Telefon</th>
                <th><i class="fa-solid fa-map me-1"></i>Yol Tarifi</th>
              </tr>
            </thead>
            <tbody id="pharmacyTbody"></tbody>
          </table>
        </div>
      </div>
      <div id="noDataMsg" class="alert alert-warning" style="display:none">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>Bu tarih için nöbetçi eczane bulunamadı.
      </div>
      <div id="errorMsg" class="alert alert-danger" style="display:none">
        <i class="fa-solid fa-circle-xmark me-2"></i>Veri yüklenirken hata oluştu. Lütfen tekrar deneyin.
      </div>
    </div>

  </div>
</div>
</main>

<footer class="footer-dark mt-5 py-4">
  <div class="container text-center text-muted small">
    <p class="mb-1">&copy; <%= new Date().getFullYear() %> Nöbetçi Eczane Rehberi</p>
    <p class="mb-0">
      <% iller.slice().sort(function(a,b){return a.name.localeCompare(b.name,'tr');}).forEach(function(prov){ %>
      <a href="/nobetci-<%= prov.slug %>" class="text-muted text-decoration-none footer-il-link"><%= prov.name %></a>
      <% }); %>
    </p>
  </div>
</footer>

<div class="modal fade" id="mapsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-red text-white">
        <h5 class="modal-title"><i class="fa-solid fa-map-location-dot me-2"></i><span id="modalPharmacyName">Yol Tarifi</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div id="mapsSpinner" class="text-center py-5"><div class="spinner-border text-danger" role="status"></div></div>
        <iframe id="mapsIframe" src="" width="100%" height="420" style="border:0;display:none;" allowfullscreen loading="lazy"></iframe>
      </div>
      <div class="modal-footer">
        <a id="mapsExternalLink" href="#" target="_blank" rel="noopener" class="btn btn-danger btn-sm">
          <i class="fa-solid fa-diamond-turn-right me-1"></i>Google Maps'te Aç
        </a>
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Kapat</button>
      </div>
    </div>
  </div>
</div>

<script>
window.PAGE_IL = '<%- il.name.replace(/'/g, "\\'") %>';
window.PAGE_ILSLUG = '<%= il.slug %>';
window.PAGE_ILCE = '';
window.PAGE_ILCESLUG = '';
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
