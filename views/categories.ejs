<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-10">
  <!-- Page Header -->
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Tüm Kategoriler</h1>
    <p class="text-gray-500">Alışveriş yaptığınız kategoriyi seçin ve en iyi kuponları keşfedin.</p>
  </div>

  <% if (categories && categories.length > 0) { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    <% categories.forEach(function(cat) { %>
    <a href="/kategori/<%= cat.slug %>" class="group rounded-2xl overflow-hidden shadow hover:shadow-xl transition border border-gray-100 hover:border-transparent flex flex-col">
      <!-- Colored Top -->
      <div class="h-3 w-full" style="background: <%= cat.color || '#FF6B00' %>;"></div>
      <div class="bg-white flex-1 p-6 flex flex-col items-center text-center">
        <div class="text-5xl mb-3"><%= cat.icon || '🏷️' %></div>
        <h3 class="text-lg font-bold text-gray-800 group-hover:text-orange-600 transition mb-1"><%= cat.name %></h3>
        <div class="flex gap-4 mt-2">
          <div class="text-center">
            <div class="text-xl font-extrabold text-gray-700"><%= cat.coupon_count || 0 %></div>
            <div class="text-xs text-gray-400">Kupon</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-extrabold text-gray-700"><%= cat.store_count || 0 %></div>
            <div class="text-xs text-gray-400">Mağaza</div>
          </div>
        </div>
        <span class="mt-4 inline-block text-sm font-semibold text-white px-4 py-1.5 rounded-full transition group-hover:opacity-90" style="background: <%= cat.color || '#FF6B00' %>;">
          Kuponları Gör →
        </span>
      </div>
    </a>
    <% }); %>
  </div>
  <% } else { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
    <div class="text-6xl mb-4">📂</div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">Kategori Bulunamadı</h3>
    <p class="text-gray-500">Henüz kategori eklenmemiş.</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>
