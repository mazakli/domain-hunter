<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/hr-head') %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "bankotahminleri.com Blog",
    "description": "At yarışı analiz, strateji ve rehber yazıları. TJK programları, AGF tabloları, bahis türleri ve tahmin ipuçları.",
    "url": "https://www.bankotahminleri.com/blog",
    "inLanguage": "tr-TR",
    "publisher": {
      "@type": "Organization",
      "name": "bankotahminleri.com",
      "url": "https://www.bankotahminleri.com",
      "logo": { "@type": "ImageObject", "url": "https://www.bankotahminleri.com/favicon.svg" }
    }
  }
  </script>
  <style>
    .blog-card {
      border: 1px solid #e9ecef;
      border-radius: 12px;
      background: #fff;
      transition: transform 0.18s, box-shadow 0.18s;
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .blog-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 28px rgba(26,107,58,0.13);
    }
    .blog-card-body { flex: 1; padding: 1.4rem; }
    .blog-card-footer { padding: 0.85rem 1.4rem; background: #f8f9fa; border-top: 1px solid #e9ecef; }
    .blog-category {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 20px;
      color: #fff;
      margin-bottom: 0.65rem;
    }
    .blog-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1a1a2e;
      line-height: 1.4;
      margin-bottom: 0.55rem;
      text-decoration: none;
      display: block;
    }
    .blog-title:hover { color: var(--hr-green); }
    .blog-excerpt { font-size: 0.87rem; color: #6c757d; line-height: 1.65; }
    .blog-meta { font-size: 0.78rem; color: #9ca3af; }
    .blog-icon-wrap {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      flex-shrink: 0;
    }
    .read-more-btn {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--hr-green);
      text-decoration: none;
    }
    .read-more-btn:hover { text-decoration: underline; color: var(--hr-green); }
    .blog-hero { background: linear-gradient(135deg, #1a6b3a 0%, #0f4a28 100%); }
  </style>
</head>
<body>

<%- include('partials/hr-navbar') %>

<!-- Hero -->
<section class="blog-hero text-white py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <nav aria-label="breadcrumb" class="mb-3">
          <ol class="breadcrumb mb-0" style="font-size:0.82rem; opacity:0.75;">
            <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item active text-white">Blog</li>
          </ol>
        </nav>
        <h1 class="fw-bold mb-2" style="font-size:2rem;">
          <i class="fa-solid fa-pen-nib me-2" style="color:#c8a400;"></i>Blog & Rehberler
        </h1>
        <p class="mb-0 opacity-75" style="font-size:1.05rem;">
          At yarışı analiz, strateji ve temel bilgi rehberleri. TJK dünyasını daha iyi anlamak için.
        </p>
      </div>
      <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
        <div style="font-size:0.85rem; opacity:0.65;">
          <i class="fa-solid fa-file-lines me-1"></i><%= posts.length %> yazı yayında
        </div>
      </div>
    </div>
  </div>
</section>

<div class="container py-5">

  <div class="row g-4">
    <% posts.forEach(function(post) { %>
    <div class="col-md-6 col-lg-4">
      <article class="blog-card shadow-sm">
        <div class="blog-card-body">
          <div class="blog-icon-wrap" style="background:<%= post.categoryColor %>22;">
            <i class="fa-solid <%= post.icon %>" style="color:<%= post.categoryColor %>; font-size:1.3rem;"></i>
          </div>
          <span class="blog-category" style="background:<%= post.categoryColor %>;"><%= post.category %></span>
          <a href="/blog/<%= post.slug %>" class="blog-title"><%= post.title %></a>
          <p class="blog-excerpt mb-0"><%= post.description %></p>
        </div>
        <div class="blog-card-footer d-flex align-items-center justify-content-between">
          <div class="blog-meta">
            <i class="fa-regular fa-calendar me-1"></i><%= post.dateLabel %>
            <span class="mx-2">·</span>
            <i class="fa-regular fa-clock me-1"></i><%= post.readTime %>
          </div>
          <a href="/blog/<%= post.slug %>" class="read-more-btn">
            Oku <i class="fa-solid fa-arrow-right ms-1" style="font-size:0.75rem;"></i>
          </a>
        </div>
      </article>
    </div>
    <% }) %>
  </div>

</div>

<%- include('partials/hr-footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
