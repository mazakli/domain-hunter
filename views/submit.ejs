<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-2xl mx-auto px-4 py-10">

  <!-- Page Header -->
  <div class="text-center mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Kupon Ekle</h1>
    <p class="text-gray-500">Bulduğunuz indirim kodlarını toplulukla paylaşın!</p>
  </div>

  <!-- Success Message -->
  <% if (success) { %>
  <div class="bg-green-50 border-2 border-green-200 text-green-800 rounded-2xl px-6 py-6 mb-8 text-center">
    <div class="text-4xl mb-3">🎉</div>
    <h3 class="text-lg font-bold mb-1">Kuponunuz İletildi!</h3>
    <p class="text-sm">Ekibimiz inceledikten sonra kuponunuz yayınlanacaktır. Katkınız için teşekkür ederiz!</p>
    <a href="/kupon-ekle" class="inline-block mt-4 px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Yeni Kupon Ekle</a>
  </div>
  <% } %>

  <!-- Error Message -->
  <% if (error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-4 mb-6 flex items-start gap-3">
    <span class="text-xl flex-shrink-0">⚠️</span>
    <span><%= error %></span>
  </div>
  <% } %>

  <!-- Submit Form -->
  <% if (!success) { %>
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
    <form action="/kupon-ekle" method="POST" class="space-y-6">

      <div>
        <label for="store_name" class="block text-sm font-semibold text-gray-700 mb-1.5">Mağaza Adı <span class="text-red-500">*</span></label>
        <% if (stores && stores.length > 0) { %>
        <input type="text" id="store_name" name="store_name" required list="stores-list"
          placeholder="Mağaza adını yazın veya seçin"
          class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        <datalist id="stores-list">
          <% stores.forEach(function(s) { %>
          <option value="<%= s.name %>"></option>
          <% }); %>
        </datalist>
        <% } else { %>
        <input type="text" id="store_name" name="store_name" required
          placeholder="örn. Trendyol, Hepsiburada"
          class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        <% } %>
      </div>

      <div>
        <label for="coupon_code" class="block text-sm font-semibold text-gray-700 mb-1.5">Kupon Kodu <span class="text-red-500">*</span></label>
        <input type="text" id="coupon_code" name="coupon_code" required
          placeholder="örn. YENI25, SUMMER2024"
          class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition font-mono tracking-wider" />
        <p class="text-xs text-gray-400 mt-1">Kod yoksa boş bırakabilirsiniz (kampanya linki için).</p>
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-gray-700 mb-1.5">Açıklama <span class="text-red-500">*</span></label>
        <textarea id="description" name="description" required rows="3"
          placeholder="Kuponun içeriğini kısaca açıklayın. örn: Tüm siparişlerde %20 indirim"
          class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition resize-none"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="discount_value" class="block text-sm font-semibold text-gray-700 mb-1.5">İndirim Değeri</label>
          <input type="text" id="discount_value" name="discount_value"
            placeholder="örn. 20, 50 TL"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        </div>
        <div>
          <label for="expiry_date" class="block text-sm font-semibold text-gray-700 mb-1.5">Son Kullanma Tarihi</label>
          <input type="date" id="expiry_date" name="expiry_date"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        </div>
      </div>

      <div class="border-t border-gray-100 pt-6">
        <h3 class="text-sm font-bold text-gray-700 mb-4">İletişim Bilgileri (İsteğe Bağlı)</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="submitter_name" class="block text-sm font-semibold text-gray-700 mb-1.5">Adınız</label>
            <input type="text" id="submitter_name" name="submitter_name"
              placeholder="Adınız"
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
          </div>
          <div>
            <label for="submitter_email" class="block text-sm font-semibold text-gray-700 mb-1.5">E-posta</label>
            <input type="email" id="submitter_email" name="submitter_email"
              placeholder="ornek@email.com"
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
          </div>
        </div>
      </div>

      <button type="submit" class="w-full text-white font-bold py-3.5 rounded-xl transition hover:opacity-90 text-lg" style="background:#FF6B00;">
        Kuponu Gönder 🚀
      </button>
    </form>
  </div>

  <!-- Info Box -->
  <div class="mt-6 bg-orange-50 rounded-xl border border-orange-100 p-5">
    <h4 class="font-bold text-gray-800 mb-2">💡 Bilgi</h4>
    <ul class="text-sm text-gray-600 space-y-1 list-disc list-inside">
      <li>Gönderilen kuponlar ekibimiz tarafından incelenir.</li>
      <li>Onaylanan kuponlar 24 saat içinde yayınlanır.</li>
      <li>Doğru ve çalışan kuponlar öncelikli onaylanır.</li>
      <li>Katkılarınız için teşekkür ederiz!</li>
    </ul>
  </div>
  <% } %>

</div>

<%- include('partials/footer') %>
</body>
</html>
