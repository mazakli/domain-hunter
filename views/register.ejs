<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">

    <!-- Logo/Brand -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block">
        <span class="text-3xl font-extrabold" style="color:#FF6B00;">kuponluk</span><span class="text-3xl font-extrabold text-gray-800">.com</span>
      </a>
      <h1 class="text-2xl font-bold text-gray-800 mt-3">Ücretsiz Hesap Oluşturun</h1>
      <p class="text-gray-500 mt-1">Kuponları kaydedin, fırsatları kaçırmayın.</p>
    </div>

    <!-- Error Message -->
    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-4 mb-6 flex items-start gap-3">
      <span class="text-xl flex-shrink-0">⚠️</span>
      <span><%= error %></span>
    </div>
    <% } %>

    <!-- Register Form -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
      <form action="/kayit" method="POST" class="space-y-5">
        <div>
          <label for="username" class="block text-sm font-semibold text-gray-700 mb-1.5">Kullanıcı Adı</label>
          <input type="text" id="username" name="username" required autocomplete="username"
            placeholder="kullanici_adi"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
          <p class="text-xs text-gray-400 mt-1">Sadece harf, rakam ve alt çizgi kullanabilirsiniz.</p>
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">E-posta Adresi</label>
          <input type="email" id="email" name="email" required autocomplete="email"
            placeholder="ornek@email.com"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        </div>
        <div>
          <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Şifre</label>
          <input type="password" id="password" name="password" required autocomplete="new-password"
            placeholder="En az 6 karakter"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        </div>
        <div>
          <label for="password2" class="block text-sm font-semibold text-gray-700 mb-1.5">Şifre Tekrar</label>
          <input type="password" id="password2" name="password2" required autocomplete="new-password"
            placeholder="Şifrenizi tekrar girin"
            class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
        </div>
        <div>
          <label class="flex items-start gap-2 text-sm text-gray-600 cursor-pointer">
            <input type="checkbox" name="terms" required class="mt-0.5 rounded border-gray-300 accent-orange-500 flex-shrink-0" />
            <span>
              <a href="/kullanim-kosullari" class="font-semibold hover:underline" style="color:#FF6B00;" target="_blank">Kullanım Koşulları</a>'nı ve
              <a href="/gizlilik-politikasi" class="font-semibold hover:underline" style="color:#FF6B00;" target="_blank">Gizlilik Politikası</a>'nı okudum ve kabul ediyorum.
            </span>
          </label>
        </div>
        <button type="submit" class="w-full text-white font-bold py-3 rounded-xl transition hover:opacity-90 text-lg" style="background:#FF6B00;">
          Üye Ol
        </button>
      </form>

      <div class="mt-6 pt-6 border-t border-gray-100 text-center">
        <p class="text-gray-600">Zaten hesabınız var mı?
          <a href="/giris" class="font-bold hover:underline" style="color:#FF6B00;">Giriş Yapın</a>
        </p>
      </div>
    </div>

    <div class="text-center mt-6 text-sm text-gray-500">
      🔒 Güvenli kayıt. Verileriniz asla üçüncü taraflarla paylaşılmaz.
    </div>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
