<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section style="background: linear-gradient(135deg, #FF6B00 0%, #ff8c00 50%, #e65c00 100%);" class="py-16 px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-3 drop-shadow">Türkiye'nin Kupon Merkezi</h1>
    <p class="text-white text-lg md:text-xl mb-8 opacity-90">En güncel indirim kuponları, promosyon kodları ve fırsatlar bir arada. Alışverişte tasarruf etmek hiç bu kadar kolay olmamıştı!</p>
    <!-- Search Bar -->
    <form action="/ara" method="GET" class="flex flex-col sm:flex-row gap-3 max-w-2xl mx-auto mb-10">
      <input type="text" name="q" placeholder="Mağaza veya kupon ara..." class="flex-1 px-5 py-3 rounded-xl text-gray-800 text-lg shadow focus:outline-none focus:ring-2 focus:ring-orange-300" />
      <button type="submit" class="bg-white font-bold px-8 py-3 rounded-xl shadow hover:bg-orange-50 transition text-lg" style="color:#FF6B00;">Ara</button>
    </form>
    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8">
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalCoupons ? stats.totalCoupons.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Aktif Kupon</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalStores ? stats.totalStores.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Mağaza</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalCategories ? stats.totalCategories.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Kategori</div>
      </div>
      <% if (stats && stats.totalUsers) { %>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats.totalUsers.toLocaleString('tr-TR') %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Üye</div>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- AdSense Placeholder -->
<!-- <div class="max-w-6xl mx-auto my-4 px-4">
  <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
</div> -->

<!-- Categories Grid -->
<% if (categories && categories.length > 0) { %>
<section class="py-12 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Kategoriler</h2>
      <a href="/kategoriler" class="text-sm font-medium hover:underline" style="color:#FF6B00;">Tümünü Gör →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% categories.forEach(function(cat) { %>
      <a href="/kategori/<%= cat.slug %>" class="flex flex-col items-center p-4 rounded-2xl border border-gray-100 hover:border-orange-300 hover:shadow-md transition group bg-gray-50 hover:bg-orange-50">
        <span class="text-3xl mb-2"><%= cat.icon || '🏷️' %></span>
        <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 text-center"><%= cat.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= cat.coupon_count || 0 %> kupon</span>
      </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Featured Stores -->
<% if (featuredStores && featuredStores.length > 0) { %>
<section class="py-12 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Öne Çıkan Mağazalar</h2>
      <a href="/magazalar" class="text-sm font-medium hover:underline" style="color:#FF6B00;">Tümünü Gör →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% featuredStores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="flex flex-col items-center p-4 rounded-2xl bg-white border border-gray-100 hover:shadow-lg hover:border-orange-200 transition group">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-14 h-14 object-contain rounded-xl mb-2" />
        <% } else { %>
        <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-2xl font-bold mb-2" style="background:#FF6B00;">
          <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
        </div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 text-center truncate w-full text-center"><%= store.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= store.coupon_count || store.active_coupons || 0 %> kupon</span>
      </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- New Coupons -->
<% if (newCoupons && newCoupons.length > 0) { %>
<section class="py-12 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">🆕 Yeni Kuponlar</h2>
      <a href="/yeni-kuponlar" class="text-sm font-semibold hover:underline" style="color:#FF6B00;">Tümünü Gör →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <% newCoupons.forEach(function(coupon) { %>
      <%- include('partials/coupon-card', { coupon: coupon }) %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

