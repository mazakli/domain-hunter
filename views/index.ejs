<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section style="background: linear-gradient(135deg, #FF6B00 0%, #ff8c00 50%, #e65c00 100%);" class="text-white py-16 px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-3 drop-shadow">Türkiye'nin Kupon Merkezi</h1>
    <p class="text-lg md:text-xl mb-8 opacity-90">En güncel indirim kuponları ve fırsatlarla alışverişlerinizde tasarruf edin.</p>
    <!-- Search Bar -->
    <form action="/ara" method="GET" class="flex max-w-2xl mx-auto shadow-xl rounded-full overflow-hidden">
      <input type="text" name="q" placeholder="Mağaza veya kupon ara..." class="flex-1 px-6 py-4 text-gray-800 text-lg focus:outline-none" />
      <button type="submit" class="bg-gray-900 hover:bg-gray-800 text-white px-8 py-4 text-lg font-semibold transition">Ara</button>
    </form>
    <!-- Stats -->
    <div class="mt-10 grid grid-cols-3 gap-4 max-w-lg mx-auto">
      <div class="bg-white bg-opacity-20 rounded-xl p-4">
        <div class="text-3xl font-extrabold"><%= stats.totalCoupons %>+</div>
        <div class="text-sm opacity-80 mt-1">Aktif Kupon</div>
      </div>
      <div class="bg-white bg-opacity-20 rounded-xl p-4">
        <div class="text-3xl font-extrabold"><%= stats.totalStores %>+</div>
        <div class="text-sm opacity-80 mt-1">Mağaza</div>
      </div>
      <div class="bg-white bg-opacity-20 rounded-xl p-4">
        <div class="text-3xl font-extrabold"><%= stats.totalCategories %>+</div>
        <div class="text-sm opacity-80 mt-1">Kategori</div>
      </div>
    </div>
  </div>
</section>

<!-- Categories Grid -->
<section class="max-w-6xl mx-auto px-4 py-12">
  <h2 class="text-2xl font-bold text-gray-800 mb-6">Kategoriler</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
    <% categories.forEach(function(cat) { %>
    <a href="/kategori/<%= cat.slug %>" class="bg-white rounded-xl shadow hover:shadow-md transition p-4 flex flex-col items-center text-center group border border-gray-100 hover:border-orange-200">
      <span class="text-3xl mb-2"><%= cat.icon || '🏷️' %></span>
      <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 transition"><%= cat.name %></span>
      <span class="text-xs text-gray-400 mt-1"><%= cat.coupon_count %> kupon</span>
    </a>
    <% }) %>
  </div>
</section>

<!-- AdSense Placeholder -->
<!-- <div class="max-w-6xl mx-auto px-4 my-4">
  <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
</div> -->

<!-- Featured Stores -->
<section class="bg-gray-50 py-12">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Öne Çıkan Mağazalar</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% featuredStores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="bg-white rounded-xl shadow hover:shadow-md transition p-4 flex flex-col items-center text-center group border border-gray-100 hover:border-orange-200">
        <% if (store.logo_url) { %>
          <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-14 h-14 object-contain rounded-lg mb-2" />
        <% } else { %>
          <div class="w-14 h-14 rounded-lg flex items-center justify-center text-white text-2xl font-bold mb-2" style="background:#FF6B00;">
            <%= store.name.charAt(0).toUpperCase() %>
          </div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 transition truncate w-full"><%= store.name %></span>
        <span class="text-xs text-gray-400 mt-1"><%= store.coupon_count || store.active_coupons || 0 %> kupon</span>
      </a>
      <% }) %>
    </div>
    <div class="text-center mt-6">
      <a href="/magazalar" class="inline-block px-8 py-3 rounded-full border-2 font-semibold transition hover:text-white hover:border-orange-500" style="color:#FF6B00; border-color:#FF6B00; hover:background:#FF6B00;">Tüm Mağazaları Gör</a>
    </div>
  </div>
</section>

<!-- New Coupons -->
<section class="max-w-6xl mx-auto px-4 py-12">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Yeni Kuponlar</h2>
    <a href="/yeni-kuponlar" class="text-sm font-semibold hover:underline" style="color:#FF6B00;">Tümünü Gör →</a>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
    <% newCoupons.forEach(function(coupon) { %>
    <%- include('partials/coupon-card', { coupon: coupon }) %>
    <% }) %>
  </div>
</section>

<!-- AdSense Placeholder -->
<!-- <div class="max-w-6xl mx-auto px-4 my-4">
  <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
</div> -->

<!-- Popular Coupons -->
<section class="bg-gray-50 py-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Popüler Kuponlar</h2>
      <a href="/populer-kuponlar" class="text-sm font-semibold hover:underline" style="color:#FF6B00;">Tümünü Gör →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <% popularCoupons.forEach(function(coupon) { %>
      <%- include('partials/coupon-card', { coupon: coupon }) %>
      <% }) %>
    </div>
  </div>
</section>

<!-- Hakkımızda Section -->
<section class="max-w-4xl mx-auto px-4 py-12 text-center">
  <h2 class="text-2xl font-bold text-gray-800 mb-4">Kuponluk.com Nedir?</h2>
  <p class="text-gray-600 text-lg leading-relaxed mb-4">
    Kuponluk.com, Türkiye'nin en büyük kupon ve indirim kodu platformudur. Yüzlerce mağazadan güncel indirim kuponlarını, promosyon kodlarını ve özel fırsatları tek bir yerden bulabilirsiniz.
  </p>
  <p class="text-gray-600 leading-relaxed">
    Her gün güncellenen binlerce kuponumuz ile alışverişlerinizde ciddi tasarruflar sağlayın. Elektronikten moda'ya, gıdadan kozmetiğe kadar her kategoride geçerli indirim kodlarına ulaşın.
  </p>
</section>

<!-- FAQ Section -->
<section class="bg-gray-50 py-12">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-gray-800 mb-8 text-center">Sık Sorulan Sorular</h2>
    <div class="space-y-4">
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Kupon kodu nasıl kullanılır?</summary>
        <p class="mt-3 text-gray-600">Kupon kodunu kopyaladıktan sonra alışveriş yaptığınız sitenin ödeme sayfasında "İndirim Kodu" veya "Promosyon Kodu" alanına yapıştırın. İndirim sepetinize otomatik olarak uygulanacaktır.</p>
      </details>
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Kuponlar ücretsiz mi?</summary>
        <p class="mt-3 text-gray-600">Evet, Kuponluk.com'daki tüm kuponlar tamamen ücretsizdir. Üye olmadan da kuponlara erişebilirsiniz.</p>
      </details>
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Kupon çalışmıyorsa ne yapmalıyım?</summary>
        <p class="mt-3 text-gray-600">Kuponun geçerlilik tarihini kontrol edin ve büyük/küçük harf duyarlılığına dikkat edin. Sorun devam ederse kupon sayfasındaki "Çalışmıyor" butonuna tıklayarak bize bildirin.</p>
      </details>
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Doğrulanmış kupon ne anlama gelir?</summary>
        <p class="mt-3 text-gray-600">Ekibimiz tarafından test edilmiş ve çalıştığı onaylanmış kuponlar "Doğrulanmış" rozeti taşır. Bu kuponların çalışma ihtimali daha yüksektir.</p>
      </details>
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Yeni kuponlardan nasıl haberdar olurum?</summary>
        <p class="mt-3 text-gray-600">Telegram kanalımıza katılarak anlık kupon bildirimlerine ulaşabilirsiniz. Ayrıca üye olarak favori mağazalarınızı takip edebilirsiniz.</p>
      </details>
      <details class="bg-white rounded-xl shadow p-5 cursor-pointer">
        <summary class="font-semibold text-gray-800 text-lg">Kupon ekleyebilir miyim?</summary>
        <p class="mt-3 text-gray-600">Evet! <a href="/kupon-ekle" class="text-orange-600 hover:underline">Kupon Ekle</a> sayfamızdan bulduğunuz kupon kodlarını paylaşabilirsiniz. Topluluğumuza katkıda bulunduğunuz için teşekkür ederiz.</p>
      </details>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
