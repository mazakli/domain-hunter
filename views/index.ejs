<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section style="background: linear-gradient(135deg, #FF6B00 0%, #ff8c00 50%, #e65c00 100%);" class="py-14 px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-3 drop-shadow">Türkiye'nin Kupon Merkezi</h1>
    <p class="text-white text-lg md:text-xl mb-8 opacity-90">En güncel indirim kuponları, promosyon kodları ve fırsatlar bir arada.</p>
    <form action="/arama" method="GET" class="flex flex-col sm:flex-row gap-3 max-w-2xl mx-auto mb-10">
      <input type="text" name="q" placeholder="Mağaza veya kupon ara..." class="flex-1 px-5 py-3.5 rounded-xl text-gray-800 text-base shadow focus:outline-none focus:ring-2 focus:ring-orange-300" />
      <button type="submit" class="bg-white font-bold px-8 py-3.5 rounded-xl shadow hover:bg-orange-50 transition" style="color:#FF6B00;">Ara</button>
    </form>
    <div class="flex flex-wrap justify-center gap-8">
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalCoupons ? stats.totalCoupons.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Aktif Kupon</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalStores ? stats.totalStores.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Mağaza</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-white"><%= stats && stats.totalCategories ? stats.totalCategories.toLocaleString('tr-TR') : '0' %>+</div>
        <div class="text-white opacity-80 text-sm mt-1">Kategori</div>
      </div>
    </div>
  </div>
</section>

<!-- Promo Slider -->
<section class="py-6 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="promo-slider relative overflow-hidden rounded-2xl" id="promoSlider">
      <!-- Slide 1 -->
      <div class="promo-slide" style="background: linear-gradient(135deg, #FF6B00, #ff8c42);">
        <div class="flex items-center justify-between h-full px-8 py-10">
          <div>
            <div class="text-white text-xs font-bold uppercase tracking-widest mb-2 opacity-80">Özel Teklif</div>
            <h3 class="text-white text-2xl md:text-3xl font-extrabold mb-3">Moda & Giyimde<br>%50'ye Kadar İndirim</h3>
            <a href="/kategori/moda-giyim" class="inline-block bg-white font-bold px-6 py-2.5 rounded-xl text-sm hover:bg-orange-50 transition" style="color:#FF6B00">Kuponları Gör</a>
          </div>
          <div class="hidden md:flex w-32 h-32 rounded-full items-center justify-center opacity-20" style="background:white">
            <svg class="w-20 h-20" fill="white" viewBox="0 0 24 24"><path d="M20.59 6.51l-7.07-7.07c-.39-.39-1.02-.39-1.41 0L.59 10.96c-.39.39-.39 1.02 0 1.41l7.07 7.07c.39.39 1.02.39 1.41 0l11.52-11.52c.39-.39.39-1.02 0-1.41z"/></svg>
          </div>
        </div>
      </div>
      <!-- Slide 2 -->
      <div class="promo-slide hidden" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
        <div class="flex items-center justify-between h-full px-8 py-10">
          <div>
            <div class="text-orange-400 text-xs font-bold uppercase tracking-widest mb-2">Teknoloji Fırsatları</div>
            <h3 class="text-white text-2xl md:text-3xl font-extrabold mb-3">Elektronik Ürünlerde<br>En İyi Kuponlar</h3>
            <a href="/kategori/elektronik" class="inline-block font-bold px-6 py-2.5 rounded-xl text-sm hover:opacity-90 transition text-white" style="background:#FF6B00">Kuponları Gör</a>
          </div>
          <div class="hidden md:flex w-32 h-32 rounded-full items-center justify-center opacity-10" style="background:#FF6B00">
            <svg class="w-20 h-20 text-white" fill="white" viewBox="0 0 24 24"><path d="M17 2H7c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-5 18c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5-4H7V4h10v12z"/></svg>
          </div>
        </div>
      </div>
      <!-- Slide 3 -->
      <div class="promo-slide hidden" style="background: linear-gradient(135deg, #0f9b8e, #16c79a);">
        <div class="flex items-center justify-between h-full px-8 py-10">
          <div>
            <div class="text-white text-xs font-bold uppercase tracking-widest mb-2 opacity-80">Yeni Üyelere Özel</div>
            <h3 class="text-white text-2xl md:text-3xl font-extrabold mb-3">Üye Ol, Ekstra<br>İndirimler Kazan</h3>
            <a href="/kayit" class="inline-block bg-white font-bold px-6 py-2.5 rounded-xl text-sm hover:bg-green-50 transition" style="color:#0f9b8e">Hemen Üye Ol</a>
          </div>
          <div class="hidden md:flex w-32 h-32 rounded-full items-center justify-center opacity-20" style="background:white">
            <svg class="w-20 h-20" fill="white" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          </div>
        </div>
      </div>

      <!-- Arrows -->
      <button id="promoPrev" class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white bg-opacity-80 hover:bg-opacity-100 flex items-center justify-center shadow transition z-10">
        <svg class="w-4 h-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button id="promoNext" class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white bg-opacity-80 hover:bg-opacity-100 flex items-center justify-center shadow transition z-10">
        <svg class="w-4 h-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>

      <!-- Dots -->
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
        <button class="promo-dot w-2 h-2 rounded-full bg-white opacity-100 transition" data-slide="0"></button>
        <button class="promo-dot w-2 h-2 rounded-full bg-white opacity-40 transition" data-slide="1"></button>
        <button class="promo-dot w-2 h-2 rounded-full bg-white opacity-40 transition" data-slide="2"></button>
      </div>
    </div>
  </div>
</section>

<!-- Brand Slider -->
<% if (sliderStores && sliderStores.length > 0) { %>
<section class="py-4 bg-gray-50 border-y border-gray-100 overflow-hidden">
  <div class="slider-wrapper">
    <div class="slider-track">
      <% sliderStores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="flex-shrink-0 flex items-center gap-2 bg-white border border-gray-100 rounded-xl px-4 py-2 hover:border-orange-300 hover:shadow transition mx-2">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-6 h-6 object-contain rounded">
        <% } else { %>
        <div class="w-6 h-6 rounded-lg flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background:#FF6B00"><%= store.name.charAt(0) %></div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 whitespace-nowrap"><%= store.name %></span>
      </a>
      <% }); %>
      <% sliderStores.forEach(function(store) { %>
      <a href="/magaza/<%= store.slug %>" class="flex-shrink-0 flex items-center gap-2 bg-white border border-gray-100 rounded-xl px-4 py-2 hover:border-orange-300 hover:shadow transition mx-2" aria-hidden="true">
        <% if (store.logo_url) { %>
        <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-6 h-6 object-contain rounded">
        <% } else { %>
        <div class="w-6 h-6 rounded-lg flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background:#FF6B00"><%= store.name.charAt(0) %></div>
        <% } %>
        <span class="text-sm font-semibold text-gray-700 whitespace-nowrap"><%= store.name %></span>
      </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- 3-Tab Brand Section -->
<section class="py-12 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Tab buttons -->
    <div class="flex flex-wrap gap-2 mb-8">
      <button class="brand-tab-btn active" data-tab="popular">
        <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
        Popüler İndirim Kodları
      </button>
      <button class="brand-tab-btn" data-tab="new">
        <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
        En Yeni İndirim Kodları
      </button>
      <button class="brand-tab-btn" data-tab="expiring">
        <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Kaçıyor
      </button>
    </div>

    <!-- Popular tab -->
    <div id="brand-tab-popular" class="brand-tab-panel">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <% if (popularBrands && popularBrands.length > 0) { %>
          <% popularBrands.forEach(function(store) { %>
          <a href="/magaza/<%= store.slug %>" class="brand-card group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-lg hover:border-orange-200 transition text-center block">
            <div class="mx-auto mb-3 flex items-center justify-center">
              <% if (store.logo_url) { %>
              <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-16 h-16 object-contain rounded-2xl border border-gray-100 p-1">
              <% } else { %>
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl font-bold" style="background:#FF6B00"><%= store.name.charAt(0).toUpperCase() %></div>
              <% } %>
            </div>
            <h3 class="font-bold text-gray-800 text-sm mb-2 truncate"><%= store.name %></h3>
            <% if (store.max_discount) { %>
            <div class="inline-block text-xs font-bold px-2.5 py-1 rounded-lg mb-2" style="background:#fff3e0;color:#FF6B00">%<%= store.max_discount %>'e kadar</div>
            <% } %>
            <div class="text-xs text-gray-400 mb-3"><%= store.coupon_count %> aktif kupon</div>
            <div class="text-xs font-semibold px-4 py-1.5 rounded-xl opacity-0 group-hover:opacity-100 transition text-white" style="background:#FF6B00">Kuponları Gör</div>
          </a>
          <% }); %>
        <% } else { %>
        <div class="col-span-4 text-center py-12 text-gray-400">Henüz kupon yok.</div>
        <% } %>
      </div>
    </div>

    <!-- New tab -->
    <div id="brand-tab-new" class="brand-tab-panel hidden">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <% if (newBrands && newBrands.length > 0) { %>
          <% newBrands.forEach(function(store) { %>
          <a href="/magaza/<%= store.slug %>" class="brand-card group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-lg hover:border-orange-200 transition text-center block">
            <div class="mx-auto mb-3 flex items-center justify-center">
              <% if (store.logo_url) { %>
              <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-16 h-16 object-contain rounded-2xl border border-gray-100 p-1">
              <% } else { %>
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl font-bold" style="background:#FF6B00"><%= store.name.charAt(0).toUpperCase() %></div>
              <% } %>
            </div>
            <h3 class="font-bold text-gray-800 text-sm mb-2 truncate"><%= store.name %></h3>
            <% if (store.max_discount) { %>
            <div class="inline-block text-xs font-bold px-2.5 py-1 rounded-lg mb-2" style="background:#fff3e0;color:#FF6B00">%<%= store.max_discount %>'e kadar</div>
            <% } %>
            <div class="text-xs text-gray-400 mb-3"><%= store.coupon_count %> aktif kupon</div>
            <div class="text-xs font-semibold px-4 py-1.5 rounded-xl opacity-0 group-hover:opacity-100 transition text-white" style="background:#FF6B00">Kuponları Gör</div>
          </a>
          <% }); %>
        <% } else { %>
        <div class="col-span-4 text-center py-12 text-gray-400">Henüz kupon yok.</div>
        <% } %>
      </div>
    </div>

    <!-- Expiring tab -->
    <div id="brand-tab-expiring" class="brand-tab-panel hidden">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <% if (expiringBrands && expiringBrands.length > 0) { %>
          <% expiringBrands.forEach(function(store) { %>
          <a href="/magaza/<%= store.slug %>" class="brand-card group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-lg hover:border-orange-200 transition text-center block">
            <div class="mx-auto mb-3 flex items-center justify-center">
              <% if (store.logo_url) { %>
              <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-16 h-16 object-contain rounded-2xl border border-gray-100 p-1">
              <% } else { %>
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl font-bold" style="background:#FF6B00"><%= store.name.charAt(0).toUpperCase() %></div>
              <% } %>
            </div>
            <h3 class="font-bold text-gray-800 text-sm mb-2 truncate"><%= store.name %></h3>
            <div class="inline-block text-xs font-bold px-2.5 py-1 rounded-lg mb-2" style="background:#fef2f2;color:#dc2626">Son fırsat!</div>
            <div class="text-xs text-gray-400 mb-3"><%= store.coupon_count %> kupon</div>
            <div class="text-xs font-semibold px-4 py-1.5 rounded-xl opacity-0 group-hover:opacity-100 transition text-white" style="background:#FF6B00">Kuponları Gör</div>
          </a>
          <% }); %>
        <% } else { %>
        <div class="col-span-4 text-center py-12 text-gray-400">Yakında sona erecek kupon yok.</div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Hakkımızda -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">Kuponluk.com Nedir?</h2>
    <p class="text-gray-600 text-lg leading-relaxed mb-8">
      Türkiye'nin en kapsamlı kupon ve indirim kodu platformu. Yüzlerce mağazadan derlenen binlerce aktif kupon kodu ile alışverişlerinizde ciddi tasarruf edin.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 rounded-2xl bg-white border border-orange-100">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background:#FF6B00">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="font-bold text-gray-800 mb-2">Doğrulanmış Kuponlar</h3>
        <p class="text-gray-600 text-sm">Tüm kuponlar ekibimiz tarafından test edilip doğrulanmaktadır.</p>
      </div>
      <div class="p-6 rounded-2xl bg-white border border-orange-100">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background:#FF6B00">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h3 class="font-bold text-gray-800 mb-2">Anlık Güncelleme</h3>
        <p class="text-gray-600 text-sm">Her gün yüzlerce yeni kupon ekleniyor, eski kuponlar kaldırılıyor.</p>
      </div>
      <div class="p-6 rounded-2xl bg-white border border-orange-100">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background:#FF6B00">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="font-bold text-gray-800 mb-2">Ücretsiz Kullanım</h3>
        <p class="text-gray-600 text-sm">Tamamen ücretsiz. Kayıt olmadan da tüm kuponları kullanabilirsiniz.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-800 text-center mb-8">Sıkça Sorulan Sorular</h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl border border-gray-100 group">
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-800 list-none">
          Kupon kodu nasıl kullanılır?
          <span class="transition-transform group-open:rotate-180" style="color:#FF6B00;">&#9660;</span>
        </summary>
        <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">
          Kupon kodunu kopyalayın, mağazanın ödeme sayfasında "İndirim Kodu" alanına yapıştırın. İndirim otomatik uygulanır.
        </div>
      </details>
      <details class="bg-gray-50 rounded-xl border border-gray-100 group">
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-800 list-none">
          Kuponlar gerçekten çalışıyor mu?
          <span class="transition-transform group-open:rotate-180" style="color:#FF6B00;">&#9660;</span>
        </summary>
        <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">
          Evet. Tüm kuponlar ekibimiz tarafından düzenli kontrol edilmektedir. "Doğrulanmış" rozeti olanlar bizzat test edilmiştir.
        </div>
      </details>
      <details class="bg-gray-50 rounded-xl border border-gray-100 group">
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-800 list-none">
          Üye olmadan kupon kullanabilir miyim?
          <span class="transition-transform group-open:rotate-180" style="color:#FF6B00;">&#9660;</span>
        </summary>
        <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">
          Evet, üye olmadan tüm kupon kodlarını görebilir ve kullanabilirsiniz.
        </div>
      </details>
      <details class="bg-gray-50 rounded-xl border border-gray-100 group">
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-800 list-none">
          Kupon eklemek istiyorum, nasıl yapabilirim?
          <span class="transition-transform group-open:rotate-180" style="color:#FF6B00;">&#9660;</span>
        </summary>
        <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">
          <a href="/kupon-gonder" class="font-semibold hover:underline" style="color:#FF6B00;">Kupon Gönder</a> sayfasından öneri gönderebilirsiniz. Ekibimiz onayladıktan sonra yayınlanır.
        </div>
      </details>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
