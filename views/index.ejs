<!-- Telegram CTA -->
<section class="py-12 px-4" style="background: linear-gradient(135deg, #0088cc, #005f8f);">
  <div class="max-w-3xl mx-auto text-center">
    <div class="text-5xl mb-4">✈️</div>
    <h2 class="text-2xl font-bold text-white mb-3">Telegram Kanalımıza Katılın</h2>
    <p class="text-blue-100 mb-6">En yeni kuponları ve fırsatları anında telefonunuza alın. Kaçırmayın!</p>
    <a href="/telegram" class="inline-block bg-white text-blue-700 font-bold px-8 py-3 rounded-xl shadow hover:bg-blue-50 transition text-lg">Kanala Katıl →</a>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
