<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Store Header -->
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mb-8">
    <div class="h-24 w-full" style="background: linear-gradient(135deg, #FF6B00, #ff8c00);"></div>
    <div class="px-6 pb-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-end gap-4 -mt-10">
        <!-- Logo -->
        <div class="flex-shrink-0">
          <% if (store.logo_url) { %>
          <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-20 h-20 rounded-2xl bg-white border-4 border-white shadow object-contain p-1" />
          <% } else { %>
          <div class="w-20 h-20 rounded-2xl bg-white border-4 border-white shadow flex items-center justify-center text-3xl font-extrabold text-white" style="background:#FF6B00;">
            <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
          </div>
          <% } %>
        </div>
        <!-- Store Info -->
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-extrabold text-gray-900"><%= store.name %></h1>
          <% if (store.category_name) { %>
          <span class="text-sm text-gray-500"><%= store.category_name %></span>
          <% } %>
        </div>
        <!-- Actions -->
        <div class="flex gap-3 flex-shrink-0">
          <% if (store.website_url) { %>
          <a href="<%= store.website_url %>" target="_blank" rel="nofollow noopener" class="flex items-center gap-2 px-5 py-2 rounded-xl border-2 font-semibold text-gray-700 border-gray-200 hover:border-orange-400 hover:text-orange-600 transition text-sm">
            🌐 Siteye Git
          </a>
          <% } %>
          <% if (currentUser) { %>
          <form action="/magaza/<%= store.slug %>/favori" method="POST">
            <button type="submit" class="flex items-center gap-2 px-5 py-2 rounded-xl border-2 font-semibold transition text-sm <%= isFavorite ? 'text-white border-transparent' : 'text-gray-700 border-gray-200 hover:border-orange-400 hover:text-orange-600' %>" style="<%= isFavorite ? 'background:#FF6B00; border-color:#FF6B00;' : '' %>">
              <%= isFavorite ? '❤️ Favorilerde' : '🤍 Favoriye Ekle' %>
            </button>
          </form>
          <% } %>
        </div>
      </div>
      <% if (store.description) { %>
      <p class="text-gray-600 mt-4 leading-relaxed"><%= store.description %></p>
      <% } %>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Main: Coupons List -->
    <div class="flex-1 min-w-0">
      <h2 class="text-xl font-bold text-gray-800 mb-5">
        <%= store.name %> Kuponları
        <% if (coupons && coupons.length > 0) { %>
        <span class="text-base font-normal text-gray-400 ml-2">(<%= coupons.length %> kupon)</span>
        <% } %>
      </h2>

      <% if (coupons && coupons.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% coupons.forEach(function(coupon) { %>
        <%- include('partials/coupon-card', { coupon: coupon }) %>
        <% }); %>
      </div>
      <% } else { %>
      <div class="bg-white rounded-2xl border border-gray-100 shadow p-12 text-center">
        <div class="text-5xl mb-4">🏷️</div>
        <h3 class="text-lg font-semibold text-gray-700 mb-2">Henüz Kupon Yok</h3>
        <p class="text-gray-500">Bu mağaza için şu an aktif kupon bulunmamaktadır.</p>
      </div>
      <% } %>
    </div>

    <!-- Sidebar: Related Stores -->
    <aside class="lg:w-64 flex-shrink-0">
      <% if (relatedStores && relatedStores.length > 0) { %>
      <div class="bg-white rounded-2xl shadow border border-gray-100 overflow-hidden sticky top-4">
        <div class="px-5 py-4 border-b border-gray-100" style="background:#FF6B00;">
          <h3 class="text-white font-bold">Benzer Mağazalar</h3>
        </div>
        <div class="divide-y divide-gray-50">
          <% relatedStores.forEach(function(s) { %>
          <a href="/magaza/<%= s.slug %>" class="flex items-center gap-3 px-5 py-3 hover:bg-orange-50 transition group">
            <% if (s.logo_url) { %>
            <img src="<%= s.logo_url %>" alt="<%= s.name %>" class="w-9 h-9 object-contain rounded-lg border border-gray-100" />
            <% } else { %>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background:#FF6B00;">
              <%= s.name ? s.name.charAt(0).toUpperCase() : '?' %>
            </div>
            <% } %>
            <div class="min-w-0">
              <div class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 truncate"><%= s.name %></div>
              <div class="text-xs text-gray-400"><%= s.active_coupons || s.coupon_count || 0 %> kupon</div>
            </div>
          </a>
          <% }); %>
        </div>
      </div>
      <% } %>
    </aside>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
