<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-3xl mx-auto px-4 py-12">

  <!-- Header -->
  <div class="text-center mb-10">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-3">İletişim</h1>
    <p class="text-gray-500">Sorularınız, önerileriniz veya işbirliği teklifleriniz için bize yazın.</p>
  </div>

  <!-- Success Message -->
  <% if (success) { %>
  <div class="bg-green-50 border-2 border-green-200 text-green-800 rounded-2xl px-6 py-6 mb-8 text-center">
    <div class="text-4xl mb-3">✅</div>
    <h3 class="text-lg font-bold mb-1">Mesajınız İletildi!</h3>
    <p class="text-sm">En kısa sürede size geri dönüş yapacağız. Teşekkür ederiz.</p>
  </div>
  <% } %>

  <!-- Error Message -->
  <% if (error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-4 mb-6 flex items-start gap-3">
    <span class="text-xl flex-shrink-0">⚠️</span>
    <span><%= error %></span>
  </div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Contact Info -->
    <div class="space-y-4">
      <div class="bg-white rounded-2xl border border-gray-100 shadow p-5">
        <div class="text-2xl mb-2">📧</div>
        <h3 class="font-bold text-gray-800 mb-1">E-posta</h3>
        <a href="mailto:iletisim@kuponluk.com" class="text-sm hover:underline" style="color:#FF6B00;">iletisim@kuponluk.com</a>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow p-5">
        <div class="text-2xl mb-2">✈️</div>
        <h3 class="font-bold text-gray-800 mb-1">Telegram</h3>
        <a href="https://t.me/kuponlukcom" target="_blank" rel="noopener" class="text-sm hover:underline" style="color:#FF6B00;">@kuponlukcom</a>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow p-5">
        <div class="text-2xl mb-2">⏰</div>
        <h3 class="font-bold text-gray-800 mb-1">Yanıt Süresi</h3>
        <p class="text-sm text-gray-600">Genellikle 24-48 saat içinde yanıt veriyoruz.</p>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="md:col-span-2">
      <% if (!success) { %>
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-7">
        <form action="/iletisim" method="POST" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Adınız <span class="text-red-500">*</span></label>
              <input type="text" id="name" name="name" required
                placeholder="Adınız Soyadınız"
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">E-posta <span class="text-red-500">*</span></label>
              <input type="email" id="email" name="email" required
                placeholder="ornek@email.com"
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition" />
            </div>
          </div>
          <div>
            <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1.5">Konu <span class="text-red-500">*</span></label>
            <select id="subject" name="subject" required class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition bg-white">
              <option value="">Konu Seçin</option>
              <option value="kupon-sorunu">Kupon Sorunu</option>
              <option value="magaza-talebi">Mağaza Ekleme Talebi</option>
              <option value="isbirligi">İşbirliği Teklifi</option>
              <option value="hata-bildirimi">Hata Bildirimi</option>
              <option value="diger">Diğer</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Mesajınız <span class="text-red-500">*</span></label>
            <textarea id="message" name="message" required rows="5"
              placeholder="Mesajınızı buraya yazın..."
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:outline-none focus:border-orange-400 text-gray-800 transition resize-none"></textarea>
          </div>
          <button type="submit" class="w-full text-white font-bold py-3 rounded-xl transition hover:opacity-90 text-base" style="background:#FF6B00;">
            Mesaj Gönder →
          </button>
        </form>
      </div>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
