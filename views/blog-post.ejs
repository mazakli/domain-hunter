<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/hr-head') %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= post.title %>",
    "description": "<%= post.description %>",
    "url": "https://www.bankotahminleri.com/blog/<%= post.slug %>",
    "datePublished": "<%= post.date %>",
    "dateModified": "<%= post.date %>",
    "inLanguage": "tr-TR",
    "author": {
      "@type": "Organization",
      "name": "bankotahminleri.com",
      "url": "https://www.bankotahminleri.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "bankotahminleri.com",
      "url": "https://www.bankotahminleri.com",
      "logo": { "@type": "ImageObject", "url": "https://www.bankotahminleri.com/favicon.svg" }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.bankotahminleri.com/blog/<%= post.slug %>"
    }
  }
  </script>
  <style>
    .post-hero { background: linear-gradient(135deg, #1a6b3a 0%, #0f4a28 100%); }
    .post-body {
      font-size: 1.02rem;
      line-height: 1.85;
      color: #2d3748;
    }
    .post-body h2 {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid #e9ecef;
    }
    .post-body h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a6b3a;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .post-body p { margin-bottom: 1rem; }
    .post-body ul { margin-bottom: 1rem; padding-left: 1.4rem; }
    .post-body li { margin-bottom: 0.35rem; }
    .post-body table { font-size: 0.9rem; }
    .post-body .alert a { font-weight: 600; }
    .post-sidebar { position: sticky; top: 80px; }
    .related-card {
      border: 1px solid #e9ecef;
      border-radius: 10px;
      padding: 1rem;
      margin-bottom: 0.75rem;
      text-decoration: none;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      transition: background 0.15s;
    }
    .related-card:hover { background: #f8f9fa; }
    .related-card-title { font-size: 0.87rem; font-weight: 600; color: #1a1a2e; line-height: 1.35; }
    .related-card-meta { font-size: 0.75rem; color: #9ca3af; margin-top: 3px; }
    .category-pill {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      padding: 3px 12px;
      border-radius: 20px;
      color: #fff;
    }
    .share-bar {
      border-top: 1px solid #e9ecef;
      border-bottom: 1px solid #e9ecef;
      padding: 1rem 0;
      margin: 2rem 0;
    }
  </style>
</head>
<body>

<%- include('partials/hr-navbar') %>

<!-- Post Hero -->
<section class="post-hero text-white py-5">
  <div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb mb-0" style="font-size:0.82rem; opacity:0.75;">
        <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">Ana Sayfa</a></li>
        <li class="breadcrumb-item"><a href="/blog" class="text-white text-decoration-none">Blog</a></li>
        <li class="breadcrumb-item active text-white"><%= post.category %></li>
      </ol>
    </nav>
    <span class="category-pill mb-3 d-inline-block" style="background:<%= post.categoryColor %>;">
      <i class="fa-solid <%= post.icon %> me-1"></i><%= post.category %>
    </span>
    <h1 class="fw-bold mb-3" style="font-size:1.85rem; max-width:760px; line-height:1.3;">
      <%= post.title %>
    </h1>
    <div class="d-flex align-items-center gap-3 flex-wrap" style="font-size:0.83rem; opacity:0.75;">
      <span><i class="fa-regular fa-calendar me-1"></i><%= post.dateLabel %></span>
      <span>·</span>
      <span><i class="fa-regular fa-clock me-1"></i><%= post.readTime %></span>
      <span>·</span>
      <span><i class="fa-solid fa-horse me-1"></i>bankotahminleri.com</span>
    </div>
  </div>
</section>

<div class="container py-5">
  <div class="row g-5">

    <!-- Main Content -->
    <div class="col-lg-8">
      <div class="post-body">
        <%- post.content %>
      </div>

      <!-- Share Bar -->
      <div class="share-bar d-flex align-items-center justify-content-between flex-wrap gap-3">
        <span style="font-size:0.87rem; font-weight:600; color:#6c757d;">Bu yazıyı faydalı buldunuz mu?</span>
        <a href="/blog" class="btn btn-outline-secondary btn-sm">
          <i class="fa-solid fa-arrow-left me-1"></i>Blog'a Dön
        </a>
      </div>

      <!-- Related Posts -->
      <% if (related && related.length > 0) { %>
      <div class="mt-4">
        <h2 class="fw-bold mb-3" style="font-size:1.1rem; border-bottom:2px solid #e9ecef; padding-bottom:0.5rem;">
          <i class="fa-solid fa-pen-nib me-2" style="color:#1a6b3a;"></i>Diğer Yazılar
        </h2>
        <div class="row g-3">
          <% related.forEach(function(r) { %>
          <div class="col-md-6">
            <a href="/blog/<%= r.slug %>" class="related-card">
              <div style="width:36px; height:36px; border-radius:8px; background:<%= r.categoryColor %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <i class="fa-solid <%= r.icon %>" style="color:<%= r.categoryColor %>; font-size:0.95rem;"></i>
              </div>
              <div>
                <div class="related-card-title"><%= r.title %></div>
                <div class="related-card-meta"><%= r.readTime %></div>
              </div>
            </a>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <aside class="post-sidebar">

        <!-- Quick Links -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:12px; overflow:hidden;">
          <div class="card-header text-white fw-bold" style="background:#1a6b3a; font-size:0.88rem;">
            <i class="fa-solid fa-link me-2"></i>Hızlı Erişim
          </div>
          <div class="card-body p-0">
            <a href="/program" class="d-flex align-items-center gap-3 p-3 text-decoration-none border-bottom" style="color:#2d3748; transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
              <i class="fa-solid fa-calendar-days" style="color:#1a6b3a; width:18px;"></i>
              <span style="font-size:0.88rem; font-weight:500;">Bugünkü Yarış Programı</span>
            </a>
            <a href="/bulten" class="d-flex align-items-center gap-3 p-3 text-decoration-none border-bottom" style="color:#2d3748; transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
              <i class="fa-solid fa-newspaper" style="color:#1a6b3a; width:18px;"></i>
              <span style="font-size:0.88rem; font-weight:500;">Günlük Bülten</span>
            </a>
            <a href="/agf" class="d-flex align-items-center gap-3 p-3 text-decoration-none border-bottom" style="color:#2d3748; transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
              <i class="fa-solid fa-chart-bar" style="color:#1a6b3a; width:18px;"></i>
              <span style="font-size:0.88rem; font-weight:500;">AGF Tablosu</span>
            </a>
            <a href="/sonuclar" class="d-flex align-items-center gap-3 p-3 text-decoration-none border-bottom" style="color:#2d3748; transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
              <i class="fa-solid fa-trophy" style="color:#c8a400; width:18px;"></i>
              <span style="font-size:0.88rem; font-weight:500;">Yarış Sonuçları</span>
            </a>
            <a href="/kupon-hesaplama" class="d-flex align-items-center gap-3 p-3 text-decoration-none" style="color:#2d3748; transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
              <i class="fa-solid fa-calculator" style="color:#dc3545; width:18px;"></i>
              <span style="font-size:0.88rem; font-weight:500;">Kupon Hesaplama</span>
            </a>
          </div>
        </div>

        <!-- All Blog Posts -->
        <div class="card border-0 shadow-sm" style="border-radius:12px; overflow:hidden;">
          <div class="card-header fw-bold" style="background:#f8f9fa; font-size:0.88rem; border-bottom:1px solid #e9ecef;">
            <i class="fa-solid fa-pen-nib me-2" style="color:#1a6b3a;"></i>Tüm Blog Yazıları
          </div>
          <div class="card-body p-0">
            <% allPosts.forEach(function(p, idx) { %>
            <a href="/blog/<%= p.slug %>"
               class="d-flex align-items-start gap-3 p-3 text-decoration-none <%= p.slug === post.slug ? '' : 'border-bottom' %>"
               style="background:<%= p.slug === post.slug ? '#f0faf4' : '' %>; color:#2d3748; transition:background .15s;"
               onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='<%= p.slug === post.slug ? '#f0faf4' : '' %>'">
              <div style="width:32px; height:32px; border-radius:8px; background:<%= p.categoryColor %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px;">
                <i class="fa-solid <%= p.icon %>" style="color:<%= p.categoryColor %>; font-size:0.8rem;"></i>
              </div>
              <div>
                <div style="font-size:0.84rem; font-weight:<%= p.slug === post.slug ? '700' : '500' %>; line-height:1.35; color:<%= p.slug === post.slug ? '#1a6b3a' : '#2d3748' %>;">
                  <%= p.title %>
                  <% if (p.slug === post.slug) { %>
                  <span class="ms-1" style="font-size:0.7rem; color:#1a6b3a;">(Bu yazı)</span>
                  <% } %>
                </div>
                <div style="font-size:0.74rem; color:#9ca3af; margin-top:2px;"><%= p.readTime %></div>
              </div>
            </a>
            <% }) %>
          </div>
        </div>

      </aside>
    </div>
  </div>
</div>

<%- include('partials/hr-footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
