<body class="d-flex flex-column min-vh-100">

<%- include('partials/navbar') %>

<main>

<section class="hero-section py-5 text-white text-center">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <h1 class="display-4 fw-bold mb-3">
          <i class="fa-solid fa-pills me-3"></i>Türkiye Nöbetçi Eczane Rehberi
        </h1>
        <p class="lead mb-4">81 ilde, tüm ilçelerde nöbetçi eczaneleri anında bulun &mdash; 724eczane.com</p>
        <div class="input-group input-group-lg search-box mx-auto" style="max-width:560px;position:relative">
          <span class="input-group-text bg-white border-0"><i class="fa-solid fa-magnifying-glass text-danger"></i></span>
          <input type="text" id="citySearch" class="form-control border-0" placeholder="" autocomplete="off">
          <button id="micBtn" class="btn btn-mic" type="button" title="Sesli ara">
            <i class="fa-solid fa-microphone"></i>
          </button>
          <button class="btn btn-warning fw-bold" onclick="doSearch()">Ara</button>
        </div>
        <div id="searchResults" class="mt-1" style="position:relative;max-width:500px;margin:0 auto;"></div>
      </div>
    </div>
  </div>
</section>

<section class="py-4 bg-light border-bottom">
  <div class="container">
    <h2 class="h5 fw-bold mb-3 text-danger"><i class="fa-solid fa-star me-2"></i>Büyükşehirler</h2>
    <div class="row g-2">
      <% var majorSlugs = ['istanbul','ankara','izmir','bursa','antalya','adana','konya','gaziantep','mersin','kayseri','diyarbakir','samsun','trabzon','eskisehir','kocaeli','hatay','manisa','sakarya']; %>
      <% majorSlugs.forEach(function(slug){ var il = iller.find(function(i){ return i.slug===slug; }); if(il){ %>
      <div class="col-6 col-sm-4 col-md-3 col-lg-2">
        <a href="/nobetci-<%= il.slug %>" class="city-card d-block text-center p-3 rounded text-decoration-none">
          <i class="fa-solid fa-location-dot text-danger mb-1 d-block"></i>
          <span class="fw-semibold small"><%= il.name %></span>
        </a>
      </div>
      <% } }); %>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <h2 class="h4 fw-bold mb-4 text-danger">
      <i class="fa-solid fa-list me-2"></i>Tüm İller (A-Z)
    </h2>
    <div class="row g-2">
      <% iller.slice().sort(function(a,b){return a.name.localeCompare(b.name,'tr');}).forEach(function(il){ %>
      <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2">
        <a href="/nobetci-<%= il.slug %>" class="province-card d-flex align-items-center gap-2 p-2 rounded text-decoration-none">
          <span class="plate-badge"><%= il.plate %></span>
          <span class="fw-medium"><%= il.name %></span>
        </a>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4 align-items-center">
      <div class="col-md-6">
        <h2 class="h4 fw-bold text-danger mb-3">
          <i class="fa-solid fa-circle-info me-2"></i>Nöbetçi Eczane Nasıl Bulunur?
        </h2>
        <ul class="list-unstyled info-list">
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Yukarıdan ilinizi seçin</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>İlçenizi seçerek daha dar arama yapın</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Dün, bugün veya yarın sekmesiyle tarih seçin</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Yol tarifi butonuyla konum izni verin, haritada rota çizilir</li>
        </ul>
      </div>
      <div class="col-md-6">
        <div class="info-card p-4 rounded-3">
          <h3 class="h5 fw-bold mb-2"><i class="fa-solid fa-clock-rotate-left me-2 text-warning"></i>Nöbet Saatleri</h3>
          <p class="text-muted small mb-0">Nöbetçi eczaneler genellikle saat <strong>09:00 – 09:00</strong> (24 saat) hizmet verir. Tatil ve hafta sonu nöbetleri farklılık gösterebilir.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5 faq-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <h2 class="h4 fw-bold text-danger mb-4">
          <i class="fa-solid fa-circle-question me-2"></i>Sıkça Sorulan Sorular
        </h2>
        <div class="accordion" id="faqAccordion">

          <div class="accordion-item border mb-2 rounded-2 overflow-hidden">
            <h3 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                Nöbetçi eczane listesi ne zaman güncelleniyor?
              </button>
            </h3>
            <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                Veriler her gün Türkiye saatiyle <strong>09:00, 12:00, 15:00, 17:00 ve 19:00</strong>'da otomatik olarak güncellenir. Yetkili API kaynağından anlık çekilen veriler, son güncelleme saatine göre önbelleğe alınır. Bu sayede gereksiz tekrarlı API çağrısı yapılmaz ve sayfa her zaman hızlı yüklenir.
              </div>
            </div>
          </div>

          <div class="accordion-item border mb-2 rounded-2 overflow-hidden">
            <h3 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                En yakın nöbetçi eczaneyi nasıl bulabilirim?
              </button>
            </h3>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                İl veya ilçe sayfasına gidip <strong>"En Yakın Eczaneyi Bul"</strong> butonuna tıklayın. Tarayıcınız konum izni isteyecektir; izin verdiğinizde bulunduğunuz noktaya en yakın nöbetçi eczane ve harita üzerinde yol tarifi otomatik olarak gösterilir. Konum verisi yalnızca tarayıcınızda işlenir, sunucuya iletilmez.
              </div>
            </div>
          </div>

          <div class="accordion-item border mb-2 rounded-2 overflow-hidden">
            <h3 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                Gece yarısı açık nöbetçi eczane var mı?
              </button>
            </h3>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                Nöbetçi eczaneler genellikle sabah <strong>09:00'dan ertesi sabah 09:00'a kadar 24 saat</strong> açık olup hafta sonu ve resmi tatillerde de hizmet verir. Sayfadaki "Bugün" sekmesinden güncel nöbetçi eczane listesine ulaşabilirsiniz. Gece açık eczane sorgulama için ilinizi seçip listeyi inceleyin.
              </div>
            </div>
          </div>

          <div class="accordion-item border rounded-2 overflow-hidden">
            <h3 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                Nöbetçi eczane bilgileri güvenilir mi?
              </button>
            </h3>
            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                724eczane.com, Türkiye Eczacılar Birliği verilerini kullanan yetkili API sağlayıcısından beslenmektedir. Tüm eczane bilgileri resmi kaynaklardan otomatik alınır; herhangi bir manuel müdahale yapılmaz. Veriler güncel ve doğru olmakla birlikte, acil durumlarda <strong>182 Alo Sağlık</strong> hattını aramanız önerilir.
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer') %>

<script>window._illerData = <%- JSON.stringify(iller) %>;</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
<script>
// Animasyonlu placeholder
(function () {
  var inp = document.getElementById('citySearch');
  if (!inp) return;
  var phrases = ['İstanbul ara...','Ankara ara...','İzmir ara...','Kadıköy ara...','Beşiktaş ara...','Çankaya ara...','Bornova ara...','Antalya ara...','Nilüfer ara...','Muratpaşa ara...'];
  var i = 0, c = 0, del = false;
  function tick() {
    if (document.activeElement === inp || inp.value) { setTimeout(tick, 400); return; }
    var ph = phrases[i];
    if (!del) {
      c++;
      inp.placeholder = ph.slice(0, c);
      if (c >= ph.length) { del = true; setTimeout(tick, 1800); return; }
      setTimeout(tick, 75);
    } else {
      c--;
      inp.placeholder = ph.slice(0, c);
      if (c <= 0) { del = false; i = (i + 1) % phrases.length; }
      setTimeout(tick, 40);
    }
  }
  tick();
})();

// Sesli arama — Chrome, Edge, Safari destekli; Firefox'ta gizlenir
(function () {
  var micBtn = document.getElementById('micBtn');
  if (!micBtn) return;
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { micBtn.style.display = 'none'; return; }
  var active = false;
  var _rec = null;

  // Eczaneyle ilgili gürültü sözcüklerini ayıklar, konum adını döner
  function parseVoiceQuery(text) {
    var stop = [
      'nöbetçi','nobetci','eczane','eczaneler','eczanesi','eczaneye',
      'yakın','yakında','yakin','yakinda','en','yakın',
      'bul','ara','bana','göster','goster','gösterir','gosterir',
      'nerede','var','mı','mi','mu','mü','hangi',
      'bugün','bugun','gece','açık','acik','olan',
      'için','icin','de','da','bir','ile','ve','veya',
      'istiyorum','lütfen','lutfen','bulmak','lazım','lazim'
    ];
    var words = text.toLowerCase().split(/\s+/);
    var filtered = words.filter(function (w) { return w && stop.indexOf(w) === -1; });
    return filtered.join(' ').trim() || text.trim();
  }

  function resetBtn(title) {
    active = false;
    micBtn.classList.remove('mic-active');
    micBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
    micBtn.title = title || 'Sesli ara';
  }

  function startRec() {
    var rec = new SR();
    rec.lang = 'tr-TR';
    rec.continuous = false;
    rec.interimResults = false;
    rec.onstart = function () {
      active = true;
      micBtn.classList.add('mic-active');
      micBtn.innerHTML = '<i class="fa-solid fa-microphone-slash"></i>';
      micBtn.title = 'Durdurmak için tıklayın';
    };
    rec.onresult = function (e) {
      var text = e.results[0][0].transcript;
      var parsed = parseVoiceQuery(text);
      var inp = document.getElementById('citySearch');
      inp.value = parsed;
      inp.dispatchEvent(new Event('input', { bubbles: true }));
      setTimeout(function () {
        var first = document.querySelector('#searchResults a');
        if (first) first.click();
      }, 600);
    };
    rec.onend = function () { resetBtn(); };
    rec.onabort = function () { resetBtn(); };
    rec.onerror = function (e) {
      resetBtn(e.error === 'not-allowed' ? 'Mikrofon izni gerekli' : 'Sesli ara');
    };
    try { rec.start(); } catch (err) { resetBtn(); }
    return rec;
  }

  micBtn.addEventListener('click', function () {
    if (active) {
      try { if (_rec) _rec.stop(); } catch (e) {}
      resetBtn();
      return;
    }
    _rec = startRec();
  });
})();
</script>
</body>
</html>
