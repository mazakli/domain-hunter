<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-4 py-10">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Tüm Mağazalar</h1>
    <p class="text-gray-500">Yüzlerce mağazanın indirim kuponlarına göz atın.</p>
  </div>

  <!-- Filters Row -->
  <div class="bg-white rounded-2xl shadow border border-gray-100 p-5 mb-8 flex flex-col sm:flex-row gap-4 items-start sm:items-center">
    <!-- Category Filter -->
    <% if (categories && categories.length > 0) { %>
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-sm font-semibold text-gray-600">Kategori:</span>
      <a href="/magazalar" class="text-xs px-3 py-1.5 rounded-full font-medium transition <%= !catSlug ? 'text-white' : 'bg-gray-100 text-gray-600 hover:bg-orange-50 hover:text-orange-600' %>" style="<%= !catSlug ? 'background:#FF6B00;' : '' %>">Tümü</a>
      <% categories.forEach(function(cat) { %>
      <a href="/magazalar?kategori=<%= cat.slug %>" class="text-xs px-3 py-1.5 rounded-full font-medium transition <%= catSlug === cat.slug ? 'text-white' : 'bg-gray-100 text-gray-600 hover:bg-orange-50 hover:text-orange-600' %>" style="<%= catSlug === cat.slug ? 'background:#FF6B00;' : '' %>">
        <%= cat.name %>
      </a>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- Alphabet Filter -->
  <div class="bg-white rounded-2xl shadow border border-gray-100 px-5 py-4 mb-8">
    <div class="flex flex-wrap gap-1">
      <a href="/magazalar<%= catSlug ? '?kategori=' + catSlug : '' %>" class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold transition <%= !letter ? 'text-white' : 'text-gray-600 hover:bg-orange-100 hover:text-orange-600' %>" style="<%= !letter ? 'background:#FF6B00;' : 'background:#f3f4f6;' %>">
        Tümü
      </a>
      <% var turkishAlpha = ['A','B','C','Ç','D','E','F','G','Ğ','H','I','İ','J','K','L','M','N','O','Ö','P','R','S','Ş','T','U','Ü','V','Y','Z']; %>
      <% turkishAlpha.forEach(function(l) { %>
      <a href="/magazalar?harf=<%= l %><%= catSlug ? '&kategori=' + catSlug : '' %>" class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold transition <%= letter === l ? 'text-white' : 'text-gray-600 hover:bg-orange-100 hover:text-orange-600' %>" style="<%= letter === l ? 'background:#FF6B00;' : 'background:#f3f4f6;' %>">
        <%= l %>
      </a>
      <% }); %>
    </div>
  </div>

  <!-- Stores Grid -->
  <% if (stores && stores.length > 0) { %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
    <% stores.forEach(function(store) { %>
    <a href="/magaza/<%= store.slug %>" class="bg-white rounded-2xl shadow hover:shadow-lg transition border border-gray-100 hover:border-orange-200 p-4 flex flex-col items-center text-center group">
      <% if (store.logo_url) { %>
      <img src="<%= store.logo_url %>" alt="<%= store.name %>" class="w-14 h-14 object-contain rounded-xl mb-3 border border-gray-100" />
      <% } else { %>
      <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-2xl font-bold mb-3" style="background:#FF6B00;">
        <%= store.name ? store.name.charAt(0).toUpperCase() : '?' %>
      </div>
      <% } %>
      <span class="text-sm font-semibold text-gray-700 group-hover:text-orange-600 transition truncate w-full text-center"><%= store.name %></span>
      <% if (store.category_name) { %>
      <span class="text-xs text-gray-400 mt-1"><%= store.category_name %></span>
      <% } %>
      <span class="inline-block mt-2 text-xs font-bold text-orange-600 bg-orange-50 px-2 py-0.5 rounded-full"><%= store.active_coupons || store.coupon_count || 0 %> kupon</span>
    </a>
    <% }); %>
  </div>
  <% } else { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow p-16 text-center">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#fff3e0;">
      <svg class="w-8 h-8" fill="none" stroke="#FF6B00" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
    </div>
    <h3 class="text-xl font-semibold text-gray-700 mb-2">Mağaza Bulunamadı</h3>
    <p class="text-gray-500">Seçili filtreler için mağaza bulunamadı. Filtrelerinizi değiştirmeyi deneyin.</p>
    <a href="/magazalar" class="inline-block mt-4 px-6 py-2 rounded-xl text-white font-semibold transition hover:opacity-90" style="background:#FF6B00;">Tüm Mağazalar</a>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>
